        <div class="modal-actions">
            <button class="modal-btn modal-btn-secondary" onclick="closeDemoModal()">Cancel</button>
            <button class="modal-btn modal-btn-primary" onclick="uploadDemoFile()">📤 Upload Demo File</button>
        </div>
    </div>
</div>

<script>
    // Store for saving results (in memory only, not localStorage)
    let matchResults = {};
    let currentSortOrder = 'desc';
    let currentSortField = 'score';
    let isAnalyzing = false;

    // Check if CV exists in local storage (this is okay to keep - it's user's CV)
    document.addEventListener('DOMContentLoaded', function () {
        const savedCV = localStorage.getItem('userCV');
        const cvStatus = document.getElementById('cvStatus');
        const nextBtn = document.getElementById('nextBtn');

        if (savedCV) {
            cvStatus.style.display = 'inline-block';
        } else {
            cvStatus.style.display = 'none';
        }

        // Inicijalno postavi sve statističke vrednosti na 0
        updateStatsFromModel();

        updateNextButton();
        updateAnalysisStatus();

        // Add click listeners to table rows
        addRowClickListeners();
    });

    // Funkcija za ažuriranje statistike iz modela (kada se učita fajl)
    function updateStatsFromModel() {
    @if (Model.ShowResults && Model.Recruiters.Any())
    {
        <text>
                document.getElementById('totalRecruiters').innerText = '@Model.Recruiters.Count';
            document.getElementById('verifiedEmails').innerText = '@Model.Recruiters.Count(r => r.EmailStatus?.ToLower() == "verified")';
            document.getElementById('withLinkedin').innerText = '@Model.Recruiters.Count(r => !string.IsNullOrEmpty(r.PersonLinkedinUrl) && r.PersonLinkedinUrl != "http://")';
            document.getElementById('withEmail').innerText = '@Model.Recruiters.Count(r => !string.IsNullOrEmpty(r.Email))';
        </text>
    }
    else
    {
        <text>
                document.getElementById('totalRecruiters').innerText = '0';
            document.getElementById('verifiedEmails').innerText = '0';
            document.getElementById('withLinkedin').innerText = '0';
            document.getElementById('withEmail').innerText = '0';
        </text>
    }
            }

    // Function to add click events to rows
    function addRowClickListeners() {
        const rows = document.querySelectorAll('#tableBody tr');
        rows.forEach(row => {
            row.addEventListener('click', function (e) {
                // Don't open modal if button or link was clicked
                if (e.target.tagName === 'BUTTON' || e.target.tagName === 'A' || e.target.closest('button') || e.target.closest('a')) {
                    return;
                }

                const index = this.getAttribute('data-index');
                if (index && matchResults[index]) {
                    displayMatchResult(matchResults[index]);
                    document.getElementById('matchModal').style.display = 'flex';
                } else if (index) {
                    showNotification('First analyze this recruiter by clicking the "AI Match" button', 'warning');
                }
            });
        });
    }

    // Display selected file name
    document.getElementById('csvFile')?.addEventListener('change', function (e) {
        var fileName = e.target.files[0]?.name;
        var label = document.getElementById('fileLabel');
        if (fileName) {
            label.innerHTML = '📄 ' + fileName;
            label.style.background = '#d4edda';
            label.style.borderColor = '#28a745';

            // Automatically submit the form when file is selected
            document.getElementById('uploadForm').submit();
        } else {
            label.innerHTML = '📁 Choose CSV file';
            label.style.background = '#e9ecef';
            label.style.borderColor = '#adb5bd';
        }
    });

    // Demo file functions
    function showDemoFileModal() {
        document.getElementById('demoFileModal').style.display = 'flex';
    }

    function closeDemoModal() {
        document.getElementById('demoFileModal').style.display = 'none';
    }

    function uploadDemoFile() {
        closeDemoModal();
        showNotification('Loading demo file...', 'info');

        // Kreiraj skriveni form i pošalji demo fajl
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/Home/Upload';
        form.style.display = 'none';
        form.enctype = 'multipart/form-data';

        // Kreiraj CSV fajl od demo podataka
        const demoContent = `Company Name for Emails,Website,First Name,Last Name,Person Linkedin Url,Title,Email,Email Status,Corporate Phone,# Employees,Company Linkedin Url,Facebook Url,Twitter Url,City,State,Country,Company Address,Company City
    GitHub,https://github.com,Alex,Chen,http://www.linkedin.com/in/alex-chen-github,Technical Recruiter - Developer Platforms,alex.chen@github.com,Verified,+1 415-735-4488,1200,https://www.linkedin.com/company/github,https://www.facebook.com/GitHub,https://twitter.com/github,Barcelona,Catalonia,Spain,"88 Colin P Kelly Jr St, San Francisco, CA, United States, 94107",San Francisco
    Goldman Sachs,https://goldmansachs.com,Sofia,Rodriguez,http://www.linkedin.com/in/sofia-rodriguez-gs,Tech Recruiter - Investment Banking Tech,sofia.rodriguez@gs.com,Verified,+1 212-902-1000,48500,https://www.linkedin.com/company/goldman-sachs,https://www.facebook.com/GoldmanSachs,https://twitter.com/GoldmanSachs,Barcelona,Catalonia,Spain,"200 West Street, New York, NY, United States, 10282",New York
    Zara,https://zara.com,David,Martinez,http://www.linkedin.com/in/david-martinez-inditex,Retail Recruitment Specialist,david.martinez@zara.com,Verified,+34 981 18 54 00,45000,https://www.linkedin.com/company/inditex,https://www.facebook.com/zara,https://twitter.com/ZARA,Barcelona,Catalonia,Spain,"Avenida de la Diputacion, Arteixo, A Coruna, Spain, 15142",Arteixo`;

        const blob = new Blob([demoContent], { type: 'text/csv' });
        const file = new File([blob], 'demo_recruiters.csv', { type: 'text/csv' });

        // Kreiraj FileList i dodaj u form
        const dataTransfer = new DataTransfer();
        dataTransfer.items.add(file);

        // Kreiraj file input i dodaj ga u form
        const fileInput = document.createElement('input');
        fileInput.type = 'file';
        fileInput.name = 'csvFile';
        fileInput.files = dataTransfer.files;
        form.appendChild(fileInput);

        // Dodaj form u body i pošalji ga
        document.body.appendChild(form);
        form.submit();

        // Očisti form posle slanja
        setTimeout(() => {
            document.body.removeChild(form);
        }, 100);
    }

    // Recruiter data from model
    let recruitersData = @Html.Raw(Model != null && Model.Recruiters != null ? Json.Serialize(Model.Recruiters) : "[]");

    // ===== BATCH ANALYSIS WITH DELAYS =====
    async function batchAnalyzeAll() {
        // Clear previous results
        matchResults = {};

        const cvData = localStorage.getItem('userCV');

        if (!cvData) {
            showNotification('Please enter your CV first.', 'warning');
            return;
        }

        if (!recruitersData || recruitersData.length === 0) {
            showNotification('No recruiter data available.', 'warning');
            return;
        }

        const totalRecruiters = recruitersData.length;
        let completed = 0;
        let failed = 0;
        let startTime = Date.now();

        // Show progress container
        document.getElementById('progressContainer').style.display = 'block';
        document.getElementById('batchAnalyzeBtn').disabled = true;
        document.getElementById('nextBtn').disabled = true;

        // Disable all AI Match buttons
        for (let i = 0; i < totalRecruiters; i++) {
            const btn = document.getElementById(`analyzeBtn-${i}`);
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '⏳ Queue...';
            }
        }

        showNotification(`Starting analysis of ${totalRecruiters} recruiters...`, 'info');

        for (let i = 0; i < totalRecruiters; i++) {
            const btn = document.getElementById(`analyzeBtn-${i}`);

            // Update progress
            const percent = Math.round((i / totalRecruiters) * 100);
            document.getElementById('progressFill').style.width = percent + '%';
            document.getElementById('progressPercent').innerHTML = percent + '%';
            document.getElementById('progressText').innerHTML = `Analyzing ${i + 1}/${totalRecruiters}: ${recruitersData[i]?.companyNameForEmails || 'N/A'}`;

            if (btn) {
                btn.innerHTML = '⏳ Analyzing...';
            }

            try {
                const response = await fetch('/Home/AnalyzeMatch', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        recruiterIndex: i,
                        recruiter: recruitersData[i],
                        cvData: cvData
                    })
                });

                const data = await response.json();

                if (data.success) {
                    matchResults[i] = data.data;
                    updateScoreInTable(i, data.data.score);
                    completed++;

                    if (btn) {
                        btn.innerHTML = '✅ Done';
                        setTimeout(() => {
                            if (btn) btn.innerHTML = '🤖 AI Match';
                        }, 2000);
                    }
                } else {
                    failed++;
                    if (btn) {
                        btn.innerHTML = '❌ Error';
                        setTimeout(() => {
                            if (btn) btn.innerHTML = '🤖 AI Match';
                        }, 2000);
                    }
                }

                updateNextButton();
                updateAnalysisStatus();

                // 1.5 second delay between requests (to avoid overloading the API)
                if (i < totalRecruiters - 1) {
                    await new Promise(resolve => setTimeout(resolve, 1500));
                }

            } catch (error) {
                console.error('Error analyzing:', error);
                failed++;
                if (btn) {
                    btn.innerHTML = '❌ Error';
                    setTimeout(() => {
                        if (btn) btn.innerHTML = '🤖 AI Match';
                    }, 2000);
                }
            }
        }

        // Finished
        let endTime = Date.now();
        let totalTime = Math.round((endTime - startTime) / 1000); // in seconds

        document.getElementById('progressFill').style.width = '100%';
        document.getElementById('progressPercent').innerHTML = '100%';
        document.getElementById('progressText').innerHTML = `Analysis completed in ${totalTime} seconds. Successful: ${completed}, Failed: ${failed}`;

        setTimeout(() => {
            document.getElementById('progressContainer').style.display = 'none';
        }, 5000);

        document.getElementById('batchAnalyzeBtn').disabled = false;

        // Enable all AI Match buttons
        for (let i = 0; i < totalRecruiters; i++) {
            const btn = document.getElementById(`analyzeBtn-${i}`);
            if (btn) {
                btn.disabled = false;
                btn.innerHTML = '🤖 AI Match';
            }
        }

        // Only enable Next button if all analyses completed successfully
        if (completed === totalRecruiters) {
            document.getElementById('nextBtn').disabled = false;
        }

        showNotification(`✅ Analysis complete! Click on any row for details.`, 'success');
        applySort(); // Apply sorting after batch analysis
        addRowClickListeners(); // Re-add click listeners to rows
    }

    // ===== HELPER FUNCTIONS =====
    function analyzeMatch(index) {
        // If we already have a result for this index, display it
        if (matchResults[index]) {
            displayMatchResult(matchResults[index]);
            document.getElementById('matchModal').style.display = 'flex';
            return;
        }

        const cvData = localStorage.getItem('userCV');

        if (!cvData) {
            showNotification('Please enter your CV first. Click on the "AI Match Setup" button.', 'warning');
            return;
        }

        if (!recruitersData || recruitersData.length === 0) {
            showNotification('No recruiter data available.', 'warning');
            return;
        }

        const recruiter = recruitersData[index];
        if (!recruiter) {
            showNotification('Recruiter not found.', 'warning');
            return;
        }

        const analyzeBtn = document.getElementById(`analyzeBtn-${index}`);
        const originalText = analyzeBtn ? analyzeBtn.innerHTML : '🤖 AI Match';

        if (analyzeBtn) {
            analyzeBtn.innerHTML = '⏳ Analyzing...';
            analyzeBtn.disabled = true;
        }

        // Show modal and loading
        document.getElementById('loadingSpinner').style.display = 'flex';
        document.getElementById('matchModal').style.display = 'flex';
        document.getElementById('matchContent').innerHTML = '';

        fetch('/Home/AnalyzeMatch', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                recruiterIndex: index,
                recruiter: recruiter,
                cvData: cvData
            })
        })
            .then(response => response.json())
            .then(data => {
                document.getElementById('loadingSpinner').style.display = 'none';
                if (analyzeBtn) {
                    analyzeBtn.innerHTML = originalText;
                    analyzeBtn.disabled = false;
                }

                if (data.success) {
                    matchResults[index] = data.data;
                    updateScoreInTable(index, data.data.score);
                    displayMatchResult(data.data);
                    updateNextButton();
                    updateAnalysisStatus();
                } else {
                    document.getElementById('matchContent').innerHTML = `
                                <div style="color: #dc3545; text-align: center; padding: 20px;">
                                    <h3 style="margin-bottom: 10px;">❌ Error</h3>
                                    <p>${data.message || 'An error occurred during analysis.'}</p>
                                </div>
                            `;
                }
            })
            .catch(error => {
                document.getElementById('loadingSpinner').style.display = 'none';
                if (analyzeBtn) {
                    analyzeBtn.innerHTML = originalText;
                    analyzeBtn.disabled = false;
                }
                document.getElementById('matchContent').innerHTML = `
                            <div style="color: #dc3545; text-align: center; padding: 20px;">
                                <h3 style="margin-bottom: 10px;">❌ Error</h3>
                                <p>An error occurred while communicating with the server.</p>
                            </div>
                        `;
            });
    }

    function updateScoreInTable(index, score) {
        const row = document.querySelector(`tr[data-index="${index}"]`);
        if (row) {
            const scoreCell = row.querySelector('.score-cell');
            const scoreSpan = scoreCell.querySelector('.score-badge');

            let scoreClass = 'score-pending';
            let scoreText = '⏳ N/A';

            if (score) {
                if (score >= 8) scoreClass = 'score-high';
                else if (score >= 5) scoreClass = 'score-medium';
                else scoreClass = 'score-low';
                scoreText = `${score}/10`;
            }

            scoreSpan.className = `score-badge ${scoreClass}`;
            scoreSpan.innerHTML = scoreText;
            scoreCell.setAttribute('data-score', score || 0);
        }
    }

    function updateNextButton() {
        const nextBtn = document.getElementById('nextBtn');
        const totalRecruiters = recruitersData ? recruitersData.length : 0;
        const analyzedCount = Object.keys(matchResults).length;

        // Enable Next button only when all recruiters have been analyzed
        if (totalRecruiters > 0 && analyzedCount === totalRecruiters) {
            nextBtn.disabled = false;
        } else {
            nextBtn.disabled = true;
        }
    }

    function updateAnalysisStatus() {
        const analyzedCount = Object.keys(matchResults).length;
        const totalCount = recruitersData ? recruitersData.length : 0;

        const analyzedSpan = document.getElementById('analyzedCount');
        const totalSpan = document.getElementById('totalCount');

        if (analyzedSpan) analyzedSpan.innerText = analyzedCount;
        if (totalSpan) totalSpan.innerText = totalCount;
    }

    function goToNextStep() {
        const results = [];

        if (Object.keys(matchResults).length === 0) {
            showNotification('No results to process. Please analyze at least one recruiter first.', 'warning');
            return;
        }

        for (let index in matchResults) {
            if (matchResults[index] && matchResults[index].score) {
                const recruiter = recruitersData[index] || {};
                const match = matchResults[index];

                results.push({
                    // Osnovni podaci o kompaniji
                    companyName: recruiter.companyNameForEmails || 'N/A',
                    website: recruiter.website || '',
                    city: recruiter.city || '',
                    country: recruiter.country || '',

                    // Podaci o recruiteru - KORISTI IMENA KOJA SE OČEKUJU U EmailGenerator
                    recruiterName: `${recruiter.firstName || ''} ${recruiter.lastName || ''}`.trim() || 'N/A',
                    recruiterTitle: recruiter.title || 'N/A',
                    recruiterEmail: recruiter.email || 'N/A',
                    emailStatus: recruiter.emailStatus || 'N/A',

                    // LinkedIn linkovi - OVO JE KLJUČNO! Koristi očekivana imena
                    recruiterLinkedIn: recruiter.personLinkedinUrl || 'N/A',  // UMESTO linkedinProfile
                    companyLinkedIn: recruiter.companyLinkedinUrl || 'N/A',   // UMESTO linkedinCompany

                    // AI Match rezultati - KORISTI VELIKA SLOVA ZA MatchScore
                    MatchScore: match.score || 0,  // VELIKO M, VELIKO S
                    reasoning: match.reasoning || '',
                    companyAnalysis: match.companyAnalysis || '',
                    locationMatch: match.locationMatch || '',
                    industryMatch: match.industryMatch || '',
                    keyFindings: match.keyFindings || '',
                    strengths: match.strengths || [],
                    weaknesses: match.weaknesses || [],

                    // Vreme analize
                    analyzedAt: new Date().toISOString()
                });
            }
        }

        if (results.length === 0) {
            showNotification('No valid results to process.', 'warning');
            return;
        }

        // Sortiranje po MatchScore
        results.sort((a, b) => b.MatchScore - a.MatchScore);

        const jsonStr = JSON.stringify(results, null, 2);

        // Debug: ispiši JSON u konzolu da vidiš šta se šalje
        console.log('JSON koji se šalje:', jsonStr);

        const blob = new Blob([jsonStr], { type: 'application/json' });
        const formData = new FormData();
        const file = new File([blob], `match_results_${new Date().toISOString().slice(0, 10)}.json`, { type: 'application/json' });
        formData.append('jsonFile', file);

        showNotification(`Sending ${results.length} results to email generator...`, 'info');

        // Umesto fetch-a, koristi form submit (pouzdanije)
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/EmailGeneration/UploadJson';
        form.enctype = 'multipart/form-data';
        form.style.display = 'none';

        const fileInput = document.createElement('input');
        fileInput.type = 'file';
        fileInput.name = 'jsonFile';

        // Postavi fajl u input
        const dataTransfer = new DataTransfer();
        dataTransfer.items.add(file);
        fileInput.files = dataTransfer.files;

        form.appendChild(fileInput);
        document.body.appendChild(form);

        // Submituj formu
        form.submit();

        // Očisti posle 2 sekunde
        setTimeout(() => {
            document.body.removeChild(form);
        }, 2000);
    }

    function applySort() {
        const sortField = document.getElementById('sortSelect').value;
        const sortOrder = currentSortOrder;
        const tbody = document.getElementById('tableBody');

        if (!tbody) return;

        const rows = Array.from(tbody.querySelectorAll('tr'));

        rows.sort((a, b) => {
            let aVal, bVal;

            switch (sortField) {
                case 'score':
                    aVal = parseFloat(a.querySelector('.score-cell')?.getAttribute('data-score') || '0');
                    bVal = parseFloat(b.querySelector('.score-cell')?.getAttribute('data-score') || '0');
                    break;
                case 'company':
                    aVal = a.getAttribute('data-company') || '';
                    bVal = b.getAttribute('data-company') || '';
                    break;
                case 'location':
                    aVal = a.getAttribute('data-location') || '';
                    bVal = b.getAttribute('data-location') || '';
                    break;
                case 'emailStatus':
                    aVal = a.getAttribute('data-emailstatus') || '';
                    bVal = b.getAttribute('data-emailstatus') || '';
                    break;
                default:
                    return 0;
            }

            if (sortOrder === 'desc') {
                return aVal > bVal ? -1 : aVal < bVal ? 1 : 0;
            } else {
                return aVal < bVal ? -1 : aVal > bVal ? 1 : 0;
            }
        });

        while (tbody.firstChild) {
            tbody.removeChild(tbody.firstChild);
        }
        rows.forEach(row => tbody.appendChild(row));

        // Re-add click listeners after sorting
        setTimeout(addRowClickListeners, 100);
    }

    function toggleSortOrder() {
        const btn = document.getElementById('sortOrderBtn');
        if (currentSortOrder === 'desc') {
            currentSortOrder = 'asc';
            btn.innerHTML = '🔼 Ascending';
        } else {
            currentSortOrder = 'desc';
            btn.innerHTML = '🔽 Descending';
        }
        applySort();
    }

    function displayMatchResult(result) {
        let scoreColor;
        if (result.score >= 8) scoreColor = '#28a745';
        else if (result.score >= 5) scoreColor = '#ffc107';
        else scoreColor = '#dc3545';

        let strengthsHtml = '';
        if (result.strengths && result.strengths.length > 0) {
            strengthsHtml = result.strengths.map(s => `<li>✅ ${s}</li>`).join('');
        } else {
            strengthsHtml = '<li style="color: #999; padding: 8px;">No specific strengths mentioned</li>';
        }

        let weaknessesHtml = '';
        if (result.weaknesses && result.weaknesses.length > 0) {
            weaknessesHtml = result.weaknesses.map(w => `<li>⚠️ ${w}</li>`).join('');
        } else {
            weaknessesHtml = '<li style="color: #999; padding: 8px;">No specific weaknesses mentioned</li>';
        }

        document.getElementById('matchContent').innerHTML = `
                    <div style="text-align: center; margin-bottom: 20px;">
                        <div class="score-circle" style="background: ${scoreColor}; margin: 0 auto;">
                            ${result.score}/10
                        </div>
                        <div style="font-size: 18px; color: #2c3e50; margin-top: 5px;">
                            Match Score
                        </div>
                    </div>

                    <div style="margin: 20px 0; padding: 15px; background: #f8f9fa; border-radius: 10px;">
                        <h4 style="color: #2c3e50; margin-bottom: 10px;">📊 Overall Assessment</h4>
                        <p style="color: #495057; line-height: 1.6;">${result.reasoning || 'No description'}</p>
                    </div>

                    <div class="analysis-grid">
                        <div class="analysis-item" style="background: #e8f4fd;">
                            <h5 style="color: #0077b5;">🏢 Company Analysis</h5>
                            <p>${result.companyAnalysis || 'N/A'}</p>
                        </div>
                        <div class="analysis-item" style="background: #f0f7e8;">
                            <h5 style="color: #28a745;">📍 Location Match</h5>
                            <p>${result.locationMatch || 'N/A'}</p>
                        </div>
                        <div class="analysis-item" style="background: #fff3cd;">
                            <h5 style="color: #856404;">🔧 Industry Match</h5>
                            <p>${result.industryMatch || 'N/A'}</p>
                        </div>
                        <div class="analysis-item" style="background: #d4edda;">
                            <h5 style="color: #155724;">💡 Key Finding</h5>
                            <p>${result.keyFindings || 'N/A'}</p>
                        </div>
                    </div>

                    <div style="margin: 20px 0;">
                        <h4 style="color: #2c3e50; margin-bottom: 10px;">💪 Strengths</h4>
                        <ul class="strengths-list">
                            ${strengthsHtml}
                        </ul>
                    </div>

                    <div style="margin: 20px 0;">
                        <h4 style="color: #2c3e50; margin-bottom: 10px;">📉 Areas for Improvement</h4>
                        <ul class="weaknesses-list">
                            ${weaknessesHtml}
                        </ul>
                    </div>

                    <div style="margin-top: 20px; padding: 15px; background: #f8f9fa; border-radius: 10px;">
                        <h5 style="color: #2c3e50; margin-bottom: 10px;">📋 Company Details:</h5>
                        <p style="color: #666; font-size: 13px; line-height: 1.6;">
                            <strong>${result.recruiter?.companyNameForEmails || 'N/A'}</strong><br>
                            📍 ${result.recruiter?.city || 'N/A'}, ${result.recruiter?.country || 'N/A'}<br>
                            👤 ${result.recruiter?.firstName || ''} ${result.recruiter?.lastName || ''} - ${result.recruiter?.title || 'N/A'}<br>
                            ${result.recruiter?.email ? '📧 ' + result.recruiter.email : ''}
                        </p>
                    </div>
                `;
    }

    function closeModal() {
        document.getElementById('matchModal').style.display = 'none';
        document.getElementById('matchContent').innerHTML = '';
    }

    function showNotification(message, type = 'info') {
        const notification = document.createElement('div');
        notification.className = `notification notification-${type}`;
        notification.textContent = message;
        document.body.appendChild(notification);

        setTimeout(() => {
            notification.style.animation = 'slideOut 0.3s ease';
            setTimeout(() => notification.remove(), 300);
        }, 5000);
    }

    // Close modals if clicked outside
    window.onclick = function (event) {
        const matchModal = document.getElementById('matchModal');
        const demoModal = document.getElementById('demoFileModal');

        if (event.target == matchModal) {
            closeModal();
        }
        if (event.target == demoModal) {
            closeDemoModal();
        }
    }
</script>