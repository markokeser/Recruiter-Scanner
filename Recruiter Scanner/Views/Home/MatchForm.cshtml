@{
    ViewData["Title"] = "AI Match Setup - Enter CV";
}

<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f4f6f9;
        margin: 0;
        padding: 20px;
    }

    .container {
        max-width: 900px;
        margin: 0 auto;
    }

    .form-container {
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }

    h2 {
        color: #2c3e50;
        margin-bottom: 30px;
        font-size: 32px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-bottom: 2px solid #e9ecef;
        padding-bottom: 15px;
    }

    .form-group {
        margin-bottom: 30px;
    }

    .form-label {
        display: block;
        margin-bottom: 15px;
        font-weight: 600;
        color: #2c3e50;
        font-size: 18px;
    }

    .cv-textarea {
        width: 100%;
        height: 400px;
        padding: 20px;
        border: 2px solid #e9ecef;
        border-radius: 15px;
        font-family: 'Courier New', monospace;
        font-size: 14px;
        line-height: 1.6;
        resize: vertical;
        transition: all 0.3s;
        background: #f8f9fa;
    }

        .cv-textarea:focus {
            border-color: #667eea;
            outline: none;
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
            background: white;
        }

    /* PDF Upload deo */
    .pdf-upload-container {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 15px;
        padding: 25px;
        margin-bottom: 25px;
        border: 2px dashed #adb5bd;
        transition: all 0.3s;
    }

        .pdf-upload-container:hover {
            border-color: #667eea;
            background: white;
        }

    .pdf-upload-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 15px;
        color: #2c3e50;
        font-weight: 600;
    }

    .file-input-wrapper {
        position: relative;
        display: inline-block;
        width: 100%;
    }

        .file-input-wrapper input[type=file] {
            position: absolute;
            left: -9999px;
            opacity: 0;
        }

    .file-label {
        background: white;
        color: #495057;
        padding: 12px 20px;
        border-radius: 10px;
        cursor: pointer;
        display: inline-block;
        border: 2px solid #dee2e6;
        transition: all 0.3s;
        font-size: 14px;
        width: 100%;
        box-sizing: border-box;
        text-align: center;
    }

        .file-label:hover {
            background: #667eea;
            color: white;
            border-color: #667eea;
        }

    .btn-upload-pdf {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 25px;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
        width: 100%;
        margin-top: 10px;
    }

        .btn-upload-pdf:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }

        .btn-upload-pdf:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .pdf-progress {
        margin-top: 15px;
        display: none;
    }

    .progress-bar {
        width: 100%;
        height: 6px;
        background: #e9ecef;
        border-radius: 3px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        width: 0%;
        transition: width 0.3s;
    }

    .pdf-status {
        font-size: 12px;
        color: #6c757d;
        margin-top: 5px;
        text-align: center;
    }
    /* Kraj PDF upload dela */

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        flex-wrap: wrap;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 15px 40px;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
        flex: 1;
        min-width: 200px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }

    .btn-secondary {
        background: white;
        color: #495057;
        padding: 15px 40px;
        border: 2px solid #e9ecef;
        border-radius: 50px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 600;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        flex: 1;
        min-width: 200px;
    }

        .btn-secondary:hover {
            background: #f8f9fa;
            border-color: #667eea;
            color: #667eea;
        }

    .char-counter {
        text-align: right;
        font-size: 12px;
        color: #6c757d;
        margin-top: 8px;
    }

    .notification {
        position: fixed;
        top: 20px;
        right: 20px;
        padding: 15px 25px;
        color: white;
        border-radius: 10px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        z-index: 1000;
        animation: slideIn 0.3s ease;
        font-weight: 500;
    }

    .notification-success {
        background: #28a745;
    }

    .notification-error {
        background: #dc3545;
    }

    .notification-info {
        background: #17a2b8;
    }

    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@keyframes slideOut {
        from {
            transform: translateX(0);
            opacity: 1;
        }

        to {
            transform: translateX(100%);
            opacity: 0;
        }
    }

    .default-cv-indicator {
        font-size: 13px;
        color: #28a745;
        margin-left: 15px;
        font-weight: normal;
    }
</style>

<div class="container">
    <div class="form-container">
        <h2>
            <span>🎯 AI Match Setup</span>
        </h2>

        <form id="cvForm">
            <!-- NOVO: PDF Upload deo -->
            <div class="pdf-upload-container">
                <div class="pdf-upload-header">
                    <span>📄 Upload PDF CV (optional)</span>
                </div>

                <div class="file-input-wrapper">
                    <input type="file" id="pdfFile" name="pdfFile" accept=".pdf" />
                    <label for="pdfFile" class="file-label" id="pdfFileLabel">📁 Choose PDF file</label>
                </div>

                <button type="button" class="btn-upload-pdf" id="uploadPdfBtn" onclick="uploadPDF()">
                    ⚡ Extract Text from PDF
                </button>

                <div id="pdfProgress" class="pdf-progress">
                    <div class="progress-bar">
                        <div id="pdfProgressFill" class="progress-fill"></div>
                    </div>
                    <div id="pdfStatus" class="pdf-status">Processing...</div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label" for="cvData">
                    📄 Your CV:
                    <span class="default-cv-indicator" id="defaultIndicator">(Default CV is loaded)</span>
                </label>
                <textarea id="cvData"
                          name="cvData"
                          class="cv-textarea"
                          placeholder="Your CV content..."></textarea>
                <div id="charCounter" class="char-counter">0 characters</div>
            </div>

            <div class="button-group">
                <button type="button" class="btn-primary" onclick="saveCVAndRedirect()">
                    💾 Save & Continue
                </button>
                <a href="/Home" class="btn-secondary">
                    ← Cancel
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    // Default CV content
    const DEFAULT_CV = `SOFTWARE ENGINEER - FULL STACK DEVELOPER

        PERSONAL INFORMATION
        Location: Barcelona, Spain (EU Citizen)
        Languages: English (Fluent), Serbian (Native), Spanish (Learning)

        PROFESSIONAL SUMMARY
        Full Stack Developer with professional experience building scalable web applications and AI integrations. Strong background in backend development with C#/.NET and Java, with a focus on clean architecture and production-ready systems.

        TECHNICAL SKILLS
        • Backend: C# / .NET Core / ASP.NET, Java, Node.js, RESTful APIs
        • Frontend: JavaScript, TypeScript, React, HTML5, CSS3
        • Databases: MySQL, SQL Server, PostgreSQL, Redis
        • AI & Tools: AI API Integration, Prompt Engineering, Git, GitHub Actions
        • Architecture: Clean Architecture, MVC, JWT Authentication

        WORK EXPERIENCE

        WICKED GAMES (Feb 2025 - Oct 2025)
        Backend / Math Developer
        • Designed mathematical models and game logic for online slot games
        • Ensured compliance with legal guidelines and optimized player experience
        • Developed backend systems using Java

        QUADRO CONSULTING (Jan 2024 - Dec 2024)
        Backend Developer
        • Worked on enterprise software with Java and C#
        • Contributed to U.S. client project - debugging and ensuring production stability
        • Full stack development across multiple technologies

        KAMELEON SOLUTIONS (Sep 2022 - Feb 2023)
        Salesforce Developer (Internship)
        • Developed components for Salesforce organizations
        • Assisted with development and administrative tasks

        FEATURED PROJECT

        RESTAURANT MANAGEMENT SYSTEM
        • Full production system used by real restaurants
        • ASP.NET Core backend with Entity Framework and MySQL
        • Role-based authentication and real-time order management
        • Live demo: zubac-matine-production.up.railway.app

        RECRUITER SCANNER
        • AI-powered email and LinkedIn message generator
        • 4 different communication tones (Professional, Enthusiastic, Exploratory, Humble)
        • Batch generation with real-time progress tracking
        • Built with C#, ASP.NET Core, and vanilla JavaScript

        EDUCATION

        FACULTY OF TECHNICAL SCIENCES, NOVI SAD
        Bachelor's degree in Computer Science`;

    // Character counter
    document.getElementById('cvData').addEventListener('input', function () {
        const count = this.value.length;
        const counter = document.getElementById('charCounter');
        counter.textContent = count + ' characters';
    });

    // Load default CV on page load
    document.addEventListener('DOMContentLoaded', function () {
        const cvField = document.getElementById('cvData');

        // Check if there's already a CV in localStorage
        const savedCV = localStorage.getItem('userCV');

        if (savedCV) {
            cvField.value = savedCV;
            document.getElementById('defaultIndicator').textContent = '(Your saved CV is loaded)';
        } else {
            cvField.value = DEFAULT_CV;
            document.getElementById('defaultIndicator').textContent = '(Default CV is loaded)';
        }

        // Trigger input to update counter
        const event = new Event('input');
        cvField.dispatchEvent(event);
    });

    // Display selected PDF file name
    document.getElementById('pdfFile')?.addEventListener('change', function (e) {
        var fileName = e.target.files[0]?.name;
        var label = document.getElementById('pdfFileLabel');
        if (fileName) {
            label.innerHTML = '📄 ' + fileName;
            label.style.background = '#d4edda';
            label.style.borderColor = '#28a745';
        } else {
            label.innerHTML = '📁 Choose PDF file';
            label.style.background = 'white';
            label.style.borderColor = '#dee2e6';
        }
    });

    // NOVO: Funkcija za upload PDF-a i ekstrakciju CV-a
    async function uploadPDF() {
        const fileInput = document.getElementById('pdfFile');
        const file = fileInput.files[0];

        if (!file) {
            showNotification('Please select a PDF file first.', 'error');
            return;
        }

        // Prikaži progress
        document.getElementById('pdfProgress').style.display = 'block';
        document.getElementById('uploadPdfBtn').disabled = true;
        document.getElementById('pdfProgressFill').style.width = '30%';
        document.getElementById('pdfStatus').textContent = 'Uploading...';

        const formData = new FormData();
        formData.append('pdfFile', file);

        try {
            const response = await fetch('/Home/ExtractCVFromPDF', {
                method: 'POST',
                body: formData
            });

            document.getElementById('pdfProgressFill').style.width = '80%';
            document.getElementById('pdfStatus').textContent = 'Processing...';

            const result = await response.json();

            if (result.success) {
                // Postavi formatirani CV u textarea
                const cvField = document.getElementById('cvData');
                cvField.value = result.data;

                // Trigger input event da se ažurira brojač
                const event = new Event('input');
                cvField.dispatchEvent(event);

                // Ažuriraj indikator
                document.getElementById('defaultIndicator').textContent = '(PDF CV loaded)';

                // Prikaži uspeh
                document.getElementById('pdfProgressFill').style.width = '100%';
                document.getElementById('pdfStatus').textContent = '✓ CV extracted successfully!';

                showNotification('CV successfully extracted from PDF!', 'success');

                // Sačekaj malo pa sakrij progress
                setTimeout(() => {
                    document.getElementById('pdfProgress').style.display = 'none';
                    document.getElementById('uploadPdfBtn').disabled = false;
                    document.getElementById('pdfProgressFill').style.width = '0%';

                    // Resetuj file input
                    fileInput.value = '';
                    document.getElementById('pdfFileLabel').innerHTML = '📁 Choose PDF file';
                    document.getElementById('pdfFileLabel').style.background = 'white';
                    document.getElementById('pdfFileLabel').style.borderColor = '#dee2e6';
                }, 2000);
            } else {
                throw new Error(result.message || 'Failed to extract CV from PDF');
            }
        } catch (error) {
            document.getElementById('pdfProgressFill').style.width = '0%';
            document.getElementById('pdfStatus').textContent = '❌ Error: ' + error.message;
            document.getElementById('uploadPdfBtn').disabled = false;

            showNotification('Error: ' + error.message, 'error');

            setTimeout(() => {
                document.getElementById('pdfProgress').style.display = 'none';
            }, 3000);
        }
    }

    function saveCVAndRedirect() {
        const cvData = document.getElementById('cvData').value;

        if (!cvData.trim()) {
            alert('Please enter your CV.');
            return;
        }

        if (cvData.length < 100) {
            alert('CV is too short. Please enter your complete CV.');
            return;
        }

        // Save to localStorage
        localStorage.setItem('userCV', cvData);

        // Show notification
        showNotification('✓ CV saved successfully!', 'success');

        // Go back to recruiters list
        setTimeout(() => {
            window.location.href = '/Home';
        }, 1500);
    }

    function showNotification(message, type) {
        const notification = document.createElement('div');
        notification.className = `notification notification-${type}`;
        notification.textContent = message;
        document.body.appendChild(notification);

        setTimeout(() => {
            notification.style.animation = 'slideOut 0.3s ease';
            setTimeout(() => notification.remove(), 300);
        }, 3000);
    }

    // Add slideOut animation
    const style = document.createElement('style');
    style.textContent = `
                @@keyframes slideOut {
                    from { transform: translateX(0); opacity: 1; }
                    to { transform: translateX(100%); opacity: 0; }
                }
            `;
    document.head.appendChild(style);
</script>