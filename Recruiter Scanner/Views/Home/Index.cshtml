@model RecruiterUploadViewModel

@{
    ViewData["Title"] = "IT Recruiters Barcelona";
}

<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f4f6f9;
        margin: 0;
        padding: 20px;
    }

    .container {
        max-width: 1400px;
        margin: 0 auto;
    }

    .header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 15px;
        background: white;
        border-radius: 15px;
        padding: 15px 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

    .left-section {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }

    .right-section {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
        margin-left: auto;
    }

    .upload-container {
        display: flex;
        align-items: center;
        gap: 15px;
        background: transparent;
        padding: 0;
        box-shadow: none;
        margin-bottom: 0;
    }

    .file-input-wrapper {
        position: relative;
        display: inline-block;
    }

        .file-input-wrapper input[type=file] {
            position: absolute;
            left: -9999px;
            opacity: 0;
        }

    .file-label {
        background: #e9ecef;
        color: #495057;
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
        display: inline-block;
        border: 2px dashed #adb5bd;
        transition: all 0.3s;
        font-size: 14px;
    }

        .file-label:hover {
            background: #dee2e6;
            border-color: #007bff;
        }

    .btn-upload {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 10px 25px;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.5px;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }

        .btn-upload:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.6);
        }

    .btn-demo {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        color: white;
        padding: 10px 25px;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.5px;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 5px 15px rgba(108, 117, 125, 0.4);
        text-decoration: none;
        display: inline-block;
    }

        .btn-demo:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(108, 117, 125, 0.6);
            color: white;
        }

    .btn-ai-setup {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
        padding: 10px 25px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
        font-size: 14px;
    }

        .btn-ai-setup:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(40, 167, 69, 0.4);
            color: white;
        }

    .stats-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin: 30px 0;
    }

    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        transition: transform 0.2s;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        }

    .stat-value {
        font-size: 36px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 5px;
    }

    .stat-label {
        color: #7f8c8d;
        font-size: 14px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .controls-container {
        background: white;
        border-radius: 12px;
        padding: 20px;
        margin: 20px 0;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

    .sort-controls {
        display: flex;
        gap: 15px;
        align-items: center;
        flex-wrap: wrap;
    }

    .sort-select {
        padding: 10px 15px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 14px;
        color: #495057;
        background: white;
        cursor: pointer;
        transition: border-color 0.3s;
    }

        .sort-select:hover {
            border-color: #667eea;
        }

        .sort-select:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }

    .sort-order-btn {
        background: #f8f9fa;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        padding: 10px 15px;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .sort-order-btn:hover {
            background: #e9ecef;
            border-color: #667eea;
        }

    .batch-analyze-btn {
        background: linear-gradient(135deg, #fd7e14 0%, #dc3545 100%);
        color: white;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

        .batch-analyze-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(253, 126, 20, 0.4);
        }

        .batch-analyze-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

    .progress-container {
        background: white;
        border-radius: 12px;
        padding: 20px;
        margin: 20px 0;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        display: none;
    }

    .progress-bar {
        width: 100%;
        height: 20px;
        background: #e9ecef;
        border-radius: 10px;
        overflow: hidden;
        margin: 10px 0;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        transition: width 0.3s ease;
        width: 0%;
    }

    .progress-text {
        text-align: center;
        color: #495057;
        font-size: 14px;
    }

    .table-wrapper {
        background: white;
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        overflow-x: auto;
    }

    .recruiter-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

        .recruiter-table th {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 15px 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-size: 12px;
            white-space: nowrap;
        }

        .recruiter-table td {
            padding: 12px 10px;
            border-bottom: 1px solid #e9ecef;
            color: #495057;
        }

        .recruiter-table tbody tr {
            cursor: pointer;
            transition: background-color 0.2s;
        }

            .recruiter-table tbody tr:hover {
                background-color: #f0f0f0 !important;
            }

            .recruiter-table tbody tr td:last-child {
                cursor: default;
            }

    .score-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
        text-align: center;
        min-width: 40px;
    }

    .score-high {
        background: #d4edda;
        color: #155724;
    }

    .score-medium {
        background: #fff3cd;
        color: #856404;
    }

    .score-low {
        background: #f8d7da;
        color: #721c24;
    }

    .score-pending {
        background: #e9ecef;
        color: #495057;
    }

    .badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .badge-verified {
        background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%);
        color: #1e4620;
    }

    .badge-unavailable {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
    }

    .badge-extrapolated {
        background: linear-gradient(135deg, #ffd89b 0%, #ffb88c 100%);
        color: #856404;
    }

    .company-info {
        max-width: 200px;
    }

    .company-name {
        font-weight: 600;
        color: #2c3e50;
        display: block;
        margin-bottom: 5px;
    }

    .company-website {
        color: #667eea;
        text-decoration: none;
        font-size: 11px;
        display: inline-block;
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

        .company-website:hover {
            text-decoration: underline;
        }

    .action-cell {
        min-width: 120px;
        cursor: default;
    }

    .linkedin-link {
        color: #0077b5;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 6px 12px;
        background: #e8f4fd;
        border-radius: 5px;
        font-size: 12px;
        margin-bottom: 5px;
        width: 100%;
        box-sizing: border-box;
    }

        .linkedin-link:hover {
            background: #0077b5;
            color: white;
        }

    .btn-ai-match {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        border-radius: 5px;
        padding: 6px 12px;
        font-size: 12px;
        cursor: pointer;
        transition: transform 0.2s;
        width: 100%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        box-sizing: border-box;
    }

        .btn-ai-match:hover {
            transform: scale(1.05);
        }

        .btn-ai-match:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

    .email-link {
        color: #2c3e50;
        text-decoration: none;
        font-size: 12px;
    }

        .email-link:hover {
            color: #667eea;
            text-decoration: underline;
        }

    .location {
        font-size: 12px;
    }

    .error-message {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
        padding: 15px 20px;
        border-radius: 10px;
        margin: 20px 0;
        text-align: center;
    }

    .success-message {
        background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%);
        color: #1e4620;
        padding: 15px 20px;
        border-radius: 10px;
        margin: 20px 0;
        text-align: center;
    }

    /* Modal Styling */
    .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.5);
        z-index: 1000;
        justify-content: center;
        align-items: center;
    }

    .modal-content {
        background: white;
        border-radius: 15px;
        width: 90%;
        max-width: 1000px;
        max-height: 90vh;
        overflow-y: auto;
        padding: 25px;
        position: relative;
        animation: modalSlideIn 0.3s ease;
    }

    .modal-close {
        position: absolute;
        top: 10px;
        right: 15px;
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: #999;
        transition: color 0.2s;
    }

        .modal-close:hover {
            color: #333;
        }

    .modal h3 {
        color: #2c3e50;
        margin-bottom: 20px;
        text-align: center;
    }

    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
    }

    .modal-btn {
        padding: 12px 30px;
        border: none;
        border-radius: 50px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        font-size: 14px;
    }

    .modal-btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }

        .modal-btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.6);
        }

    .modal-btn-secondary {
        background: #e9ecef;
        color: #495057;
    }

        .modal-btn-secondary:hover {
            background: #dee2e6;
        }

    .demo-file-preview {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 15px;
        margin: 20px 0;
        border: 1px solid #e9ecef;
    }

    .demo-file-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 2px solid #667eea;
    }

    .demo-file-title {
        font-weight: 600;
        color: #2c3e50;
        font-size: 16px;
    }

    .demo-file-badge {
        background: #667eea;
        color: white;
        padding: 5px 15px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
    }

    .demo-file-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

        .demo-file-table th {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 10px 8px;
            font-weight: 600;
            text-align: left;
            font-size: 12px;
        }

        .demo-file-table td {
            padding: 8px;
            border-bottom: 1px solid #e9ecef;
            color: #495057;
        }

        .demo-file-table tr:last-child td {
            border-bottom: none;
        }

        .demo-file-table tr:hover {
            background-color: #e9ecef;
        }

    .loading-spinner {
        display: none;
        justify-content: center;
        align-items: center;
        padding: 40px;
    }

    .spinner {
        border: 4px solid #f3f3f3;
        border-top: 4px solid #667eea;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
    }

    .score-circle {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 36px;
        font-weight: bold;
        color: white;
    }

    .analysis-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin: 20px 0;
    }

    .analysis-item {
        padding: 15px;
        border-radius: 10px;
        background: #f8f9fa;
    }

        .analysis-item h5 {
            margin-bottom: 8px;
            font-size: 14px;
        }

        .analysis-item p {
            color: #495057;
            font-size: 13px;
            line-height: 1.5;
        }

    .strengths-list, .weaknesses-list {
        list-style: none;
        padding: 0;
        margin: 10px 0;
    }

        .strengths-list li {
            padding: 8px 12px;
            margin-bottom: 5px;
            background: #d4edda;
            border-radius: 5px;
            color: #155724;
            font-size: 13px;
        }

        .weaknesses-list li {
            padding: 8px 12px;
            margin-bottom: 5px;
            background: #f8d7da;
            border-radius: 5px;
            color: #721c24;
            font-size: 13px;
        }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    @@keyframes modalSlideIn {
        from {
            transform: translateY(-50px);
            opacity: 0;
        }

        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@keyframes slideOut {
        from {
            transform: translateX(0);
            opacity: 1;
        }

        to {
            transform: translateX(100%);
            opacity: 0;
        }
    }

    .notification {
        position: fixed;
        top: 20px;
        right: 20px;
        padding: 15px 20px;
        border-radius: 5px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        z-index: 1000;
        animation: slideIn 0.3s ease;
    }

    .notification-warning {
        background: #ffc107;
        color: #212529;
    }

    .notification-info {
        background: #17a2b8;
        color: white;
    }

    .notification-success {
        background: #28a745;
        color: white;
    }

    .cv-badge {
        background: #28a745;
        color: white;
        padding: 3px 8px;
        border-radius: 3px;
        font-size: 11px;
        margin-left: 10px;
    }

    .bottom-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 20px;
        gap: 15px;
    }

    .btn-next {
        background: linear-gradient(135deg, #fd7e14 0%, #dc3545 100%);
        color: white;
        padding: 12px 35px;
        border: none;
        border-radius: 50px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: 0 5px 15px rgba(253, 126, 20, 0.3);
        font-size: 16px;
        min-width: 150px;
    }

        .btn-next:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(253, 126, 20, 0.4);
        }

        .btn-next:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

    .analysis-status {
        background: white;
        border-radius: 50px;
        padding: 10px 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        font-size: 14px;
        color: #2c3e50;
    }

        .analysis-status span {
            font-weight: 600;
            color: #667eea;
        }
</style>

<div class="container">
    <!-- Header row sa svim dugmadima u jednoj liniji -->
    <div class="header-row">
        <div class="left-section">
            <div class="upload-container">
                <div class="file-input-wrapper">
                    <input type="file" id="csvFile" name="csvFile" accept=".csv,.json" required />
                    <label for="csvFile" class="file-label" id="fileLabel">📁 Choose CSV file</label>
                </div>
                <button type="submit" form="uploadForm" class="btn-upload">Upload CSV file</button>
                <button onclick="showDemoFileModal()" class="btn-demo">Use Demo file</button>
            </div>
        </div>

        <div class="right-section">
            <a href="/Home/MatchForm" class="btn-ai-setup">
                🎯 AI Match Setup <span id="cvStatus" class="cv-badge" style="display: none;">✓ CV Saved</span>
            </a>
        </div>
    </div>

    <form id="uploadForm" asp-action="Upload" method="post" enctype="multipart/form-data" style="display: none;">
        <input type="file" name="csvFile" id="hiddenFileInput" />
    </form>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error-message">
            ⚠️ @Model.ErrorMessage
        </div>
    }

    <!-- Stats Container - Uvek vidljiv, prikazuje 0 dok se ne učita fajl -->
    <div class="stats-container">
        <div class="stat-card">
            <div class="stat-value" id="totalRecruiters">0</div>
            <div class="stat-label">Total Recruiters</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" id="verifiedEmails">0</div>
            <div class="stat-label">Verified Emails</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" id="withLinkedin">0</div>
            <div class="stat-label">With LinkedIn</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" id="withEmail">0</div>
            <div class="stat-label">With Email</div>
        </div>
    </div>

    @if (Model.ShowResults)
    {
        if (Model.Recruiters.Any())
        {
            <div class="controls-container">
                <div class="sort-controls">
                    <span style="color: #2c3e50; font-weight: 600;">Sort by:</span>
                    <select id="sortSelect" class="sort-select" onchange="applySort()">
                        <option value="score">Score (AI Match)</option>
                        <option value="company">Company Name</option>
                        <option value="location">Location</option>
                        <option value="emailStatus">Email Status</option>
                    </select>
                    <button id="sortOrderBtn" class="sort-order-btn" onclick="toggleSortOrder()">
                        🔽 Descending
                    </button>
                </div>
            </div>

            <div id="progressContainer" class="progress-container">
                <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                    <span style="font-weight: 600;">Analysis in progress...</span>
                    <span id="progressPercent">0%</span>
                </div>
                <div class="progress-bar">
                    <div id="progressFill" class="progress-fill" style="width: 0%;"></div>
                </div>
                <div id="progressText" class="progress-text">Preparing...</div>
            </div>

            <div class="table-wrapper">
                <table class="recruiter-table" id="recruiterTable">
                    <thead>
                        <tr>
                            <th>Company</th>
                            <th>Full Name</th>
                            <th>Position</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th>Phone</th>
                            <th>Location</th>
                            <th>AI Score</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="tableBody">
                        @{
                            int index = 0;
                        }
                        @foreach (var recruiter in Model.Recruiters)
                        {
                            <tr data-index="@index" data-company="@recruiter.CompanyNameForEmails" data-location="@recruiter.City" data-emailstatus="@recruiter.EmailStatus">
                                <td>
                                    <div class="company-info">
                                        <span class="company-name">@recruiter.CompanyNameForEmails</span>
                                        @if (!string.IsNullOrEmpty(recruiter.Website) && recruiter.Website != "https://")
                                        {
                                            <a href="@recruiter.Website" target="_blank" class="company-website" title="@recruiter.Website">
                                                🌐 @recruiter.Website.Replace("https://", "").Replace("http://", "")
                                            </a>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <strong>@recruiter.FirstName @recruiter.LastName</strong>
                                </td>
                                <td>
                                    <div style="max-width: 200px; word-wrap: break-word;">
                                        @recruiter.Title
                                    </div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(recruiter.Email))
                                    {
                                        <a href="mailto:@recruiter.Email" class="email-link" title="@recruiter.Email">
                                            @recruiter.Email
                                        </a>
                                    }
                                    else
                                    {
                                        <span style="color: #999;">N/A</span>
                                    }
                                </td>
                                <td>
                                    @if (recruiter.EmailStatus?.ToLower() == "verified")
                                    {
                                        <span class="badge badge-verified">✓ Verified</span>
                                    }
                                    else if (recruiter.EmailStatus?.ToLower() == "unavailable")
                                    {
                                        <span class="badge badge-unavailable">✗ Unavailable</span>
                                    }
                                    else if (recruiter.EmailStatus?.ToLower() == "extrapolated")
                                    {
                                        <span class="badge badge-extrapolated">⟲ Extrapolated</span>
                                    }
                                    else if (!string.IsNullOrEmpty(recruiter.EmailStatus))
                                    {
                                        <span class="badge">@recruiter.EmailStatus</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(recruiter.CorporatePhone))
                                    {
                                        <span>@recruiter.CorporatePhone</span>
                                    }
                                    else
                                    {
                                        <span style="color: #999;">-</span>
                                    }
                                </td>
                                <td>
                                    <div class="location">
                                        @if (!string.IsNullOrEmpty(recruiter.City))
                                        {
                                            @recruiter.City
                                        }
                                        @if (!string.IsNullOrEmpty(recruiter.Country))
                                        {
                                            <br />
                                            <small style="color: #999;">@recruiter.Country</small>
                                        }
                                    </div>
                                </td>
                                <td class="score-cell" data-score="0">
                                    <span class="score-badge score-pending">⏳ N/A</span>
                                </td>
                                <td class="action-cell">
                                    @if (!string.IsNullOrEmpty(recruiter.PersonLinkedinUrl) && recruiter.PersonLinkedinUrl != "http://")
                                    {
                                        <a href="@recruiter.PersonLinkedinUrl" target="_blank" class="linkedin-link">
                                            🔗 LinkedIn
                                        </a>
                                    }
                                    <button onclick="analyzeMatch(@index); event.stopPropagation();" class="btn-ai-match" id="analyzeBtn-@index">
                                        🤖 AI Match
                                    </button>
                                </td>
                            </tr>
                            index++;
                        }
                    </tbody>
                </table>
            </div>

            <!-- Bottom actions with Batch Analyze and Next button -->
            <div class="bottom-actions">
                <button id="batchAnalyzeBtn" class="batch-analyze-btn" onclick="batchAnalyzeAll()">
                    ⚡ Batch Analyze All
                </button>
                <div class="analysis-status" id="analysisStatus">
                    Analyzed: <span id="analyzedCount">0</span> / <span id="totalCount">@Model.Recruiters.Count</span>
                </div>
                <button id="nextBtn" class="btn-next" onclick="goToNextStep()" disabled>
                    Next →
                </button>
            </div>
        }
        else
        {
            <div class="error-message">
                No data in the file. Check the CSV file format.
            </div>
        }
    }
</div>

<!-- Modal for AI results -->
<div id="matchModal" class="modal">
    <div class="modal-content">
        <button class="modal-close" onclick="closeModal()">&times;</button>
        <h3>🤖 AI Match Analysis</h3>

        <div id="loadingSpinner" class="loading-spinner">
            <div class="spinner"></div>
        </div>

        <div id="matchContent"></div>
    </div>
</div>

<!-- Modal for Demo File Preview -->
