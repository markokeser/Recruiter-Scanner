    <!-- DATA SECTION - prikazuje se samo kada IMA podataka -->
    <div class="data-section">
        

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error-message">⚠️ @Model.ErrorMessage</div>
        }

        <div class="stats-container">
            <div class="stat-card"><div class="stat-value" id="totalRecruiters">0</div><div class="stat-label">Total Recruiters</div></div>
            <div class="stat-card"><div class="stat-value" id="verifiedEmails">0</div><div class="stat-label">Verified Emails</div></div>
            <div class="stat-card"><div class="stat-value" id="withLinkedin">0</div><div class="stat-label">With LinkedIn</div></div>
            <div class="stat-card"><div class="stat-value" id="withEmail">0</div><div class="stat-label">With Email</div></div>
        </div>

        @if (Model.ShowResults && Model.Recruiters.Any())
        {
            <div class="controls-container">
                <div class="sort-controls">
                    <span style="color: #2c3e50; font-weight: 600;">Sort by:</span>
                    <select id="sortSelect" class="sort-select" onchange="applySort()">
                        <option value="score">Score (AI Match)</option>
                        <option value="company">Company Name</option>
                        <option value="location">Location</option>
                        <option value="emailStatus">Email Status</option>
                    </select>
                    <button id="sortOrderBtn" class="sort-order-btn" onclick="toggleSortOrder()">🔽 Descending</button>
                </div>
            </div>

            <div class="mobile-actions">
                <button id="mobileBatchAnalyzeBtn" class="batch-analyze-btn" onclick="batchAnalyzeAll()">Analyze All</button>
                <button id="mobileNextBtn" class="btn-next" onclick="goToNextStep()" disabled>Next</button>
            </div>

            <div id="progressContainer" class="progress-container">
                <div style="display: flex; justify-content: space-between; margin-bottom: 10px;">
                    <span style="font-weight: 600;">Analysis in progress...</span>
                    <span id="progressPercent">0%</span>
                </div>
                <div class="progress-bar"><div id="progressFill" class="progress-fill" style="width: 0%;"></div></div>
                <div id="progressText" class="progress-text">Preparing...</div>
            </div>

            <div class="table-wrapper">
                <table class="recruiter-table" id="recruiterTable">
                    <thead>
                        <tr><th>Company</th><th>Full Name</th><th>Position</th><th>Email</th><th>Status</th><th>Phone</th><th>Location</th><th>AI Score</th><th>Actions</th></tr>
                    </thead>
                    <tbody id="tableBody">
                        @{
                            int index = 0;
                        }
                        @foreach (var recruiter in Model.Recruiters)
                        {
                            <tr data-index="@index" data-company="@recruiter.CompanyNameForEmails" data-location="@recruiter.City" data-emailstatus="@recruiter.EmailStatus">
                                <td data-label="Company">
                                    <div class="company-info">
                                        <span class="company-name">@recruiter.CompanyNameForEmails</span>
                                        @if (!string.IsNullOrEmpty(recruiter.Website) && recruiter.Website != "https://")
                                        {
                                            <a href="@recruiter.Website" target="_blank" class="company-website">🌐 @recruiter.Website.Replace("https://", "").Replace("http://", "")</a>
                                        }
                                    </div>
                                </td>
                                <td data-label="Name"><strong>@recruiter.FirstName @recruiter.LastName</strong></td>
                                <td data-label="Position"><div style="max-width: 200px; word-wrap: break-word;">@recruiter.Title</div></td>
                                <td data-label="Email">
                                    @if (!string.IsNullOrEmpty(recruiter.Email))
                                    {
                                        <a href="mailto:@recruiter.Email" class="email-link">@recruiter.Email</a>
                                    }
                                    else
                                    {
                                        <span style="color: #999;">N/A</span>
                                    }
                                </td>
                                <td data-label="Status">
                                    @if (recruiter.EmailStatus?.ToLower() == "verified")
                                    {
                                        <span class="badge badge-verified">✓ Verified</span>
                                    }
                                    else if (!string.IsNullOrEmpty(recruiter.EmailStatus))
                                    {
                                        <span class="badge">@recruiter.EmailStatus</span>
                                    }
                                </td>
                                <td data-label="Phone">
                                    @if (!string.IsNullOrEmpty(recruiter.CorporatePhone))
                                    {
                                        <span>@recruiter.CorporatePhone</span>
                                    }
                                    else
                                    {
                                        <span style="color: #999;">-</span>
                                    }
                                </td>
                                <td data-label="Location">
                                    <div class="location">
                                        @if (!string.IsNullOrEmpty(recruiter.City)) { @recruiter.City }
                                        @if (!string.IsNullOrEmpty(recruiter.Country)) { <br /><small style="color: #999;">@recruiter.Country</small> }
                                    </div>
                                </td>
                                <td class="score-cell" data-score="0" data-label="Score"><span class="score-badge score-pending">⏳ N/A</span></td>
                                <td class="action-cell" data-label="Actions">
                                    @if (!string.IsNullOrEmpty(recruiter.PersonLinkedinUrl) && recruiter.PersonLinkedinUrl != "http://")
                                    {
                                        <a href="@recruiter.PersonLinkedinUrl" target="_blank" class="linkedin-link">🔗 LinkedIn</a>
                                    }
                                </td>
                            </tr>
                            index++;
                        }
                    </tbody>
                </table>
            </div>

            <div class="bottom-actions">
                <button id="batchAnalyzeBtn" class="batch-analyze-btn" onclick="batchAnalyzeAll()">Analyze All</button>
                <button id="nextBtn" class="btn-next" onclick="goToNextStep()" disabled>Next</button>
            </div>
        }
        else if (Model.ShowResults && !Model.Recruiters.Any())
        {
            <div class="error-message">No data in the file. Click the "Load Demo Data" button above to see how it works!</div>
        }
    </div>
</div>

<!-- Modal for AI results -->
