@model RecruiterUploadViewModel

@{
    ViewData["Title"] = "AI Recruiters Match - Barcelona";
}

<style>
    /* ===== BASE STYLES ===== */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
        min-height: 100vh;
        padding: 20px;
    }

    .container {
        max-width: 1400px;
        margin: 0 auto;
    }

    /* ===== HERO SECTION ===== */
    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 24px;
        padding: 50px 40px;
        margin-bottom: 40px;
        color: white;
        text-align: center;
        box-shadow: 0 20px 40px rgba(102, 126, 234, 0.25);
        position: relative;
        overflow: hidden;
    }

    .hero-section::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
        pointer-events: none;
    }

    .hero-title {
        font-size: 2.8rem;
        font-weight: 800;
        margin-bottom: 15px;
        letter-spacing: -0.5px;
    }

    .hero-subtitle {
        font-size: 1.2rem;
        opacity: 0.95;
        margin-bottom: 30px;
        max-width: 650px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.6;
    }

    .hero-badge {
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(10px);
        border-radius: 50px;
        padding: 8px 24px;
        display: inline-block;
        margin-bottom: 20px;
        font-weight: 600;
        font-size: 0.9rem;
        letter-spacing: 1px;
    }

    .hero-buttons {
        display: flex;
        gap: 20px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-hero-primary {
        background: white;
        color: #667eea;
        padding: 14px 35px;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        font-size: 1rem;
        font-weight: 700;
        transition: all 0.3s ease;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .btn-hero-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    }

    .btn-hero-secondary {
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(10px);
        color: white;
        padding: 14px 35px;
        border: 2px solid rgba(255,255,255,0.5);
        border-radius: 50px;
        text-decoration: none;
        font-size: 1rem;
        font-weight: 700;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
    }

    .btn-hero-secondary:hover {
        background: white;
        color: #667eea;
        border-color: white;
        transform: translateY(-2px);
    }

    /* ===== INTRO SECTION (prikazuje se samo kada NEMA podataka) ===== */
    .intro-section {
        display: @(Model.ShowResults ? "none" : "block");
    }

    .info-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 25px;
        margin-bottom: 50px;
    }

    .info-card {
        background: white;
        border-radius: 20px;
        padding: 30px 25px;
        text-align: center;
        box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
        border: 1px solid rgba(0,0,0,0.05);
    }

    .info-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }

    .info-icon {
        font-size: 52px;
        margin-bottom: 20px;
    }

    .info-card h3 {
        color: #2c3e50;
        margin-bottom: 12px;
        font-size: 1.3rem;
    }

    .info-card p {
        color: #7f8c8d;
        font-size: 0.9rem;
        line-height: 1.6;
        margin-bottom: 15px;
    }

    .info-link {
        color: #667eea;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: gap 0.3s;
    }

    .info-link:hover {
        gap: 8px;
    }

    /* ===== OR DIVIDER ===== */
    .or-divider {
        text-align: center;
        margin: 40px 0;
        position: relative;
    }

    .or-divider-line {
        position: absolute;
        top: 50%;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, #dee2e6, #dee2e6, transparent);
        z-index: 0;
    }

    .or-divider-text {
        background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
        display: inline-block;
        padding: 10px 25px;
        border-radius: 50px;
        font-weight: 700;
        color: #6c757d;
        position: relative;
        z-index: 1;
        font-size: 1rem;
        letter-spacing: 2px;
    }

    /* ===== DEMO SECTION ===== */
    .demo-section {
        background: white;
        border-radius: 28px;
        margin-bottom: 40px;
        overflow: hidden;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        border: 1px solid rgba(102, 126, 234, 0.2);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .demo-section:hover {
        transform: translateY(-5px);
        box-shadow: 0 25px 45px rgba(0,0,0,0.15);
    }

    .demo-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 25px 30px;
        text-align: center;
        color: white;
    }

    .demo-header h2 {
        font-size: 1.8rem;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
    }

    .demo-header p {
        opacity: 0.9;
        font-size: 0.95rem;
    }

    .demo-badge {
        background: rgba(255,255,255,0.2);
        border-radius: 50px;
        padding: 5px 15px;
        font-size: 0.8rem;
        display: inline-block;
        margin-top: 10px;
    }

    .demo-content {
        padding: 30px;
    }

    .demo-preview-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 25px;
        margin-bottom: 30px;
    }

    .demo-preview-card {
        background: #f8f9fa;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    .demo-preview-header {
        background: #e9ecef;
        padding: 15px 20px;
        font-weight: 700;
        color: #2c3e50;
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 1rem;
    }

    .demo-preview-body {
        padding: 20px;
        max-height: 350px;
        overflow-y: auto;
    }

    .demo-preview-body pre {
        font-family: 'Courier New', monospace;
        font-size: 11px;
        line-height: 1.5;
        color: #495057;
        white-space: pre-wrap;
        word-wrap: break-word;
        margin: 0;
        background: white;
        padding: 15px;
        border-radius: 10px;
    }

    .demo-recruiter-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        background: white;
        border-radius: 10px;
        overflow: hidden;
    }

    .demo-recruiter-table th {
        background: #e9ecef;
        padding: 10px 12px;
        text-align: left;
        font-weight: 600;
        color: #2c3e50;
    }

    .demo-recruiter-table td {
        padding: 8px 12px;
        border-bottom: 1px solid #e9ecef;
    }

    .demo-recruiter-table tr:last-child td {
        border-bottom: none;
    }

    .demo-footer {
        text-align: center;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
    }

    .btn-demo-large {
        background: linear-gradient(135deg, #fd7e14 0%, #dc3545 100%);
        color: white;
        border: none;
        padding: 16px 45px;
        font-size: 1.2rem;
        font-weight: 700;
        border-radius: 60px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 10px 25px rgba(253, 126, 20, 0.3);
        display: inline-flex;
        align-items: center;
        gap: 12px;
    }

    .btn-demo-large:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 35px rgba(253, 126, 20, 0.4);
    }

    .demo-note {
        margin-top: 15px;
        font-size: 0.8rem;
        color: #6c757d;
    }

    /* ===== DATA SECTION (prikazuje se samo kada IMA podataka) ===== */
    .data-section {
        display: @(Model.ShowResults ? "block" : "none");
    }

    .header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 15px;
        background: white;
        border-radius: 15px;
        padding: 15px 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    }

    .left-section {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
    }

    .right-section {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: wrap;
        margin-left: auto;
    }

    .upload-container {
        display: flex;
        align-items: center;
        gap: 15px;
        background: transparent;
        padding: 0;
        margin-bottom: 0;
    }

    .file-input-wrapper {
        position: relative;
        display: inline-block;
    }

    .file-input-wrapper input[type=file] {
        position: absolute;
        left: -9999px;
        opacity: 0;
    }

    .file-label {
        background: #e9ecef;
        color: #495057;
        padding: 10px 20px;
        border-radius: 8px;
        cursor: pointer;
        display: inline-block;
        border: 2px dashed #adb5bd;
        transition: all 0.3s;
        font-size: 14px;
    }

    .file-label:hover {
        background: #dee2e6;
        border-color: #667eea;
    }

    .btn-upload {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 10px 25px;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }

    .btn-upload:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.6);
    }

    .btn-demo {
        background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
        color: white;
        padding: 10px 25px;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
        box-shadow: 0 5px 15px rgba(108, 117, 125, 0.4);
    }

    .btn-demo:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(108, 117, 125, 0.6);
    }

    .btn-ai-setup {
        background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
        color: white;
        padding: 10px 25px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
        font-size: 14px;
    }

    .btn-ai-setup:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(40, 167, 69, 0.4);
        color: white;
    }

    .stats-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin: 30px 0;
    }

    .stat-card {
        background: white;
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        transition: transform 0.2s;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
    }

    .stat-value {
        font-size: 36px;
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 5px;
    }

    .stat-label {
        color: #7f8c8d;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .controls-container {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin: 20px 0;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 15px;
    }

    .sort-controls {
        display: flex;
        gap: 15px;
        align-items: center;
        flex-wrap: wrap;
    }

    .sort-select {
        padding: 10px 15px;
        border: 2px solid #e9ecef;
        border-radius: 10px;
        font-size: 14px;
        color: #495057;
        background: white;
        cursor: pointer;
        transition: border-color 0.3s;
    }

    .sort-select:hover {
        border-color: #667eea;
    }

    .sort-order-btn {
        background: #f8f9fa;
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 10px 15px;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .sort-order-btn:hover {
        background: #e9ecef;
        border-color: #667eea;
    }

    .batch-analyze-btn {
        background: linear-gradient(135deg, #fd7e14 0%, #dc3545 100%);
        color: white;
        padding: 12px 35px;
        border: none;
        border-radius: 50px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        box-shadow: 0 5px 15px rgba(253, 126, 20, 0.3);
        font-size: 16px;
        min-width: 200px;
    }

    .batch-analyze-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(253, 126, 20, 0.4);
    }

    .batch-analyze-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    .progress-container {
        background: white;
        border-radius: 16px;
        padding: 20px;
        margin: 20px 0;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        display: none;
    }

    .progress-bar {
        width: 100%;
        height: 20px;
        background: #e9ecef;
        border-radius: 10px;
        overflow: hidden;
        margin: 10px 0;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        transition: width 0.3s ease;
        width: 0%;
    }

    .progress-text {
        text-align: center;
        color: #495057;
        font-size: 14px;
    }

    .table-wrapper {
        background: white;
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        overflow-x: auto;
    }

    .recruiter-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }

    .recruiter-table th {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 15px 10px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 12px;
        white-space: nowrap;
    }

    .recruiter-table td {
        padding: 12px 10px;
        border-bottom: 1px solid #e9ecef;
        color: #495057;
    }

    .recruiter-table tbody tr {
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .recruiter-table tbody tr:hover {
        background-color: #f8f9fa;
    }

    .score-badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
        text-align: center;
        min-width: 40px;
    }

    .score-high {
        background: #d4edda;
        color: #155724;
    }

    .score-medium {
        background: #fff3cd;
        color: #856404;
    }

    .score-low {
        background: #f8d7da;
        color: #721c24;
    }

    .score-pending {
        background: #e9ecef;
        color: #495057;
    }

    .badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 50px;
        font-size: 11px;
        font-weight: 600;
    }

    .badge-verified {
        background: linear-gradient(135deg, #84fab0 0%, #8fd3f4 100%);
        color: #1e4620;
    }

    .badge-unavailable {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
    }

    .badge-extrapolated {
        background: linear-gradient(135deg, #ffd89b 0%, #ffb88c 100%);
        color: #856404;
    }

    .company-info {
        max-width: 200px;
    }

    .company-name {
        font-weight: 600;
        color: #2c3e50;
        display: block;
        margin-bottom: 5px;
    }

    .company-website {
        color: #667eea;
        text-decoration: none;
        font-size: 11px;
        display: inline-block;
        max-width: 180px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .company-website:hover {
        text-decoration: underline;
    }

    .linkedin-link {
        color: #0077b5;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 8px 12px;
        background: #e8f4fd;
        border-radius: 8px;
        font-size: 12px;
        transition: all 0.2s;
    }

    .linkedin-link:hover {
        background: #0077b5;
        color: white;
    }

    .email-link {
        color: #2c3e50;
        text-decoration: none;
        font-size: 12px;
    }

    .email-link:hover {
        color: #667eea;
        text-decoration: underline;
    }

    .location {
        font-size: 12px;
    }

    .cv-badge {
        background: #28a745;
        color: white;
        padding: 3px 8px;
        border-radius: 3px;
        font-size: 11px;
        margin-left: 10px;
    }

    .bottom-actions {
        display: flex;
        justify-content: flex-end;
        margin-top: 20px;
        gap: 15px;
    }

    .btn-next {
        background: linear-gradient(135deg, #fd7e14 0%, #dc3545 100%);
        color: white;
        padding: 12px 35px;
        border: none;
        border-radius: 50px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s;
        font-size: 16px;
        min-width: 200px;
    }

    .btn-next:hover:not(:disabled) {
        transform: translateY(-2px);
    }

    .btn-next:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .error-message {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
        padding: 15px 20px;
        border-radius: 12px;
        margin: 20px 0;
        text-align: center;
    }

    /* Modal */
    .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.6);
        backdrop-filter: blur(5px);
        z-index: 1000;
        justify-content: center;
        align-items: center;
    }

    .modal-content {
        background: white;
        border-radius: 24px;
        width: 90%;
        max-width: 1000px;
        max-height: 90vh;
        overflow-y: auto;
        padding: 30px;
        position: relative;
        animation: modalSlideIn 0.3s ease;
    }

    .modal-close {
        position: absolute;
        top: 15px;
        right: 20px;
        background: none;
        border: none;
        font-size: 28px;
        cursor: pointer;
        color: #999;
        transition: color 0.2s;
    }

    .modal-close:hover {
        color: #333;
    }

    .modal-actions {
        display: flex;
        justify-content: flex-end;
        gap: 15px;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
    }

    .modal-btn {
        padding: 12px 30px;
        border: none;
        border-radius: 50px;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s;
        font-size: 14px;
    }

    .modal-btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .modal-btn-primary:hover {
        transform: translateY(-2px);
    }

    .modal-btn-secondary {
        background: #e9ecef;
        color: #495057;
    }

    .modal-btn-secondary:hover {
        background: #dee2e6;
    }

    .demo-file-preview {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 15px;
        margin: 20px 0;
        border: 1px solid #e9ecef;
    }

    .demo-file-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 2px solid #667eea;
    }

    .demo-file-title {
        font-weight: 600;
        color: #2c3e50;
        font-size: 16px;
    }

    .demo-file-badge {
        background: #667eea;
        color: white;
        padding: 5px 15px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 600;
    }

    .demo-file-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .demo-file-table th {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 10px 8px;
        font-weight: 600;
        text-align: left;
        font-size: 12px;
    }

    .demo-file-table td {
        padding: 8px;
        border-bottom: 1px solid #e9ecef;
        color: #495057;
    }

    .loading-spinner {
        display: none;
        justify-content: center;
        align-items: center;
        padding: 40px;
    }

    .spinner {
        border: 4px solid #f3f3f3;
        border-top: 4px solid #667eea;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
    }

    .score-circle {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 36px;
        font-weight: bold;
        color: white;
    }

    .analysis-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin: 20px 0;
    }

    .analysis-item {
        padding: 15px;
        border-radius: 12px;
        background: #f8f9fa;
    }

    .analysis-item h5 {
        margin-bottom: 8px;
        font-size: 14px;
    }

    .strengths-list, .weaknesses-list {
        list-style: none;
        padding: 0;
        margin: 10px 0;
    }

    .strengths-list li {
        padding: 8px 12px;
        margin-bottom: 5px;
        background: #d4edda;
        border-radius: 8px;
        color: #155724;
        font-size: 13px;
    }

    .weaknesses-list li {
        padding: 8px 12px;
        margin-bottom: 5px;
        background: #f8d7da;
        border-radius: 8px;
        color: #721c24;
        font-size: 13px;
    }

    .notification {
        position: fixed;
        top: 20px;
        right: 20px;
        padding: 15px 25px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        z-index: 1100;
        animation: slideIn 0.3s ease;
        font-weight: 500;
    }

    .notification-warning {
        background: #ffc107;
        color: #212529;
    }

    .notification-info {
        background: #17a2b8;
        color: white;
    }

    .notification-success {
        background: #28a745;
        color: white;
    }

    .mobile-actions {
        display: none;
    }

    @@keyframes spin {
        100% {
            transform: rotate(360deg);
        }
    }

    @@keyframes modalSlideIn {
        from {
            transform: translateY(-30px);
            opacity: 0;
        }
        to {
            transform: translateY(0);
            opacity: 1;
        }
    }

    @@keyframes slideIn {
        from {
            transform: translateX(100%);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@keyframes slideOut {
        from {
            transform: translateX(0);
            opacity: 1;
        }
        to {
            transform: translateX(100%);
            opacity: 0;
        }
    }

    @@media (max-width: 900px) {
