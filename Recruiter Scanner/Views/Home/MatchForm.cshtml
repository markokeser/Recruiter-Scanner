@{
    ViewData["Title"] = "AI Match Setup - Enter CV";
}

<style>
    body {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background-color: #f4f6f9;
        margin: 0;
        padding: 20px;
    }

    .container {
        max-width: 900px;
        margin: 0 auto;
    }

    .form-container {
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }

    h2 {
        color: #2c3e50;
        margin-bottom: 20px;
        font-size: 32px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .info-box {
        background: linear-gradient(135deg, #667eea10 0%, #764ba210 100%);
        border-left: 5px solid #667eea;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 30px;
    }

        .info-box h4 {
            color: #2c3e50;
            margin-bottom: 10px;
            font-size: 18px;
        }

        .info-box ul {
            margin: 10px 0 0 20px;
            color: #495057;
            line-height: 1.6;
        }

        .info-box li {
            margin-bottom: 8px;
        }

    .form-group {
        margin-bottom: 25px;
    }

    .form-label {
        display: block;
        margin-bottom: 10px;
        font-weight: 600;
        color: #2c3e50;
        font-size: 16px;
    }

    .cv-textarea {
        width: 100%;
        height: 400px;
        padding: 20px;
        border: 2px solid #e9ecef;
        border-radius: 15px;
        font-family: 'Courier New', monospace;
        font-size: 14px;
        line-height: 1.6;
        resize: vertical;
        transition: all 0.3s;
        background: #f8f9fa;
    }

        .cv-textarea:focus {
            border-color: #667eea;
            outline: none;
            box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
            background: white;
        }

        .cv-textarea::placeholder {
            color: #adb5bd;
            font-style: italic;
        }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        flex-wrap: wrap;
    }

    .btn-primary {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 15px 40px;
        border: none;
        border-radius: 50px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 600;
        transition: transform 0.2s, box-shadow 0.2s;
        flex: 1;
        min-width: 200px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }

    .btn-secondary {
        background: white;
        color: #495057;
        padding: 15px 40px;
        border: 2px solid #e9ecef;
        border-radius: 50px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 600;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        flex: 1;
        min-width: 200px;
    }

        .btn-secondary:hover {
            background: #f8f9fa;
            border-color: #667eea;
            color: #667eea;
        }

    .sample-cv {
        margin-top: 30px;
        background: #f8f9fa;
        border-radius: 12px;
        padding: 20px;
    }

        .sample-cv h4 {
            color: #2c3e50;
            margin-bottom: 15px;
            font-size: 16px;
        }

    .sample-btn {
        background: none;
        border: 2px dashed #adb5bd;
        padding: 10px 20px;
        border-radius: 8px;
        color: #495057;
        cursor: pointer;
        font-size: 14px;
        transition: all 0.3s;
        width: 100%;
        text-align: left;
    }

        .sample-btn:hover {
            border-color: #667eea;
            color: #667eea;
            background: white;
        }

    .char-counter {
        text-align: right;
        font-size: 12px;
        color: #6c757d;
        margin-top: 8px;
    }

        .char-counter.warning {
            color: #ffc107;
        }

        .char-counter.danger {
            color: #dc3545;
        }
</style>

<div class="container">
    <div class="form-container">
        <h2>
            <span>🎯 AI Match Setup</span>
        </h2>

        <div class="info-box">
            <h4>📋 CV Entry Instructions</h4>
            <ul>
                <li>Copy your entire CV content (you can paste from Word, PDF, or text file)</li>
                <li>AI will analyze your CV and compare it with each recruiter</li>
                <li>You'll receive a score from 1-10 for each company</li>
                <li>Detailed explanation of why it's a good or bad match</li>
                <li>Suggestions for contacting recruiters</li>
            </ul>
        </div>

        <form id="cvForm">
            <div class="form-group">
                <label class="form-label" for="cvData">
                    📄 Enter your CV (copy/paste):
                </label>
                <textarea id="cvData"
                          name="cvData"
                          class="cv-textarea"
                          placeholder="Paste your CV here... e.g.:

John Smith
Senior Software Engineer

TECHNICAL SKILLS:
• C# / .NET Core / ASP.NET
• Python / JavaScript / React
• SQL Server / MongoDB
• Git / GitHub
• RESTful APIs / GraphQL
• Cloud Services (AWS/Azure)"></textarea>
                <div id="charCounter" class="char-counter">0 characters</div>
            </div>

            <div class="button-group">
                <button type="button" class="btn-primary" onclick="saveCVAndRedirect()">
                    💾 Save CV & Go to Recruiters List
                </button>
                <a href="/Home" class="btn-secondary">
                    ← Back to List
                </a>
            </div>
        </form>

        <div class="sample-cv">
            <h4>🔽 Sample CV for Testing (click to insert):</h4>
            <button class="sample-btn" onclick="insertSampleCV()">
                📋 Insert Sample CV
            </button>
        </div>
    </div>
</div>

<script>
    // Character counter
    document.getElementById('cvData').addEventListener('input', function () {
        const count = this.value.length;
        const counter = document.getElementById('charCounter');
        counter.textContent = count + ' characters';

        if (count > 5000) {
            counter.className = 'char-counter warning';
        } else if (count > 10000) {
            counter.className = 'char-counter danger';
        } else {
            counter.className = 'char-counter';
        }
    });

    function saveCVAndRedirect() {
        const cvData = document.getElementById('cvData').value;

        if (!cvData.trim()) {
            alert('Please enter your CV.');
            return;
        }

        if (cvData.length < 100) {
            alert('CV is too short. Please enter your complete CV.');
            return;
        }

        // Save to localStorage
        localStorage.setItem('userCV', cvData);

        // Show notification
        showNotification('✓ CV successfully saved!', 'success');

        // Go to recruiters list
        setTimeout(() => {
            window.location.href = '/Home';
        }, 1500);
    }

    function insertSampleCV() {
        const sampleCV = `SOFTWARE ENGINEER - FULL STACK DEVELOPER

    PERSONAL INFORMATION
    Location: Barcelona, Spain (EU Citizen)
    Languages: English (Native), Spanish (Fluent)

    PROFESSIONAL SUMMARY
    Full Stack Developer with 6+ years of experience building scalable web applications and developer tools. Passionate about open source, clean code, and developer experience. Strong background in both frontend and backend technologies with a focus on modern JavaScript frameworks and cloud architecture.

    TECHNICAL SKILLS
    • Frontend: React, TypeScript, Next.js, HTML5, CSS3, Tailwind
    • Backend: Node.js, Python, C#/.NET, RESTful APIs, GraphQL
    • Databases: PostgreSQL, MongoDB, Redis
    • DevOps: Docker, AWS (EC2, S3), CI/CD, GitHub Actions
    • Tools: Git, VS Code, Postman, Jira, Figma
    • Testing: Jest, Cypress, Playwright

    WORK EXPERIENCE

    TECHNOLOGY SOLUTIONS INC. (2022 - Present)
    Senior Full Stack Developer
    • Led development of internal developer portal used by 200+ engineers
    • Built and maintained CI/CD pipelines using GitHub Actions
    • Mentored junior developers and conducted code reviews
    • Implemented OAuth2 authentication system for multiple client applications
    • Reduced API response time by 40% through query optimization and caching

    DIGITAL INNOVATIONS LTD (2019 - 2022)
    Full Stack Developer
    • Developed e-commerce platform processing 50k+ daily transactions
    • Integrated payment gateways (Stripe, PayPal) and third-party APIs
    • Built responsive frontend with React and Redux
    • Optimized database queries resulting in 60% faster load times
    • Participated in agile development process with bi-weekly sprints

    STARTUP HUB (2018 - 2019)
    Junior Developer
    • Contributed to MVP development for 3 startup projects
    • Built RESTful APIs using Node.js and Express
    • Collaborated with UX designers to implement responsive interfaces
    • Participated in hackathons and won "Best Technical Solution" award

    OPEN SOURCE CONTRIBUTIONS
    • Contributor to React core documentation
    • Maintainer of popular GitHub Actions workflow templates
    • Created and maintained 5 open source libraries with 1000+ GitHub stars

    EDUCATION

    MASTER OF COMPUTER SCIENCE (2016 - 2018)
    Technical University of Barcelona
    • Thesis: "Developer Experience in Modern CI/CD Pipelines"
    • GPA: 3.8/4.0

    BACHELOR OF SOFTWARE ENGINEERING (2013 - 2016)
    University of Catalonia
    • Focus: Web Technologies and Distributed Systems

    CERTIFICATIONS
    • AWS Certified Developer – Associate (2023)
    • GitHub Actions Certification (2024)
    • MongoDB Developer Certification (2023)

    PROJECTS

    DEVELOPER DASHBOARD
    • Built developer productivity dashboard used by 500+ engineers
    • Integrated with GitHub API to track pull requests and deployments
    • Open sourced with 800+ GitHub stars

    API GATEWAY TEMPLATE
    • Created reusable API gateway template with authentication and rate limiting
    • Downloaded 10k+ times on npm
    • Used by 50+ companies in production

    LANGUAGES
    • English (Native)
    • Spanish (Fluent - C1)
    • Catalan (Basic)`;

        document.getElementById('cvData').value = sampleCV;

        // Trigger input event to update counter
        const event = new Event('input');
        document.getElementById('cvData').dispatchEvent(event);

        showNotification('✓ Sample CV loaded!', 'success');
    }

    function showNotification(message, type) {
        const notification = document.createElement('div');
        notification.style.cssText = `
                    position: fixed;
                    top: 20px;
                    right: 20px;
                    padding: 15px 25px;
                    background: ${type === 'success' ? '#28a745' : '#17a2b8'};
                    color: white;
                    border-radius: 10px;
                    box-shadow: 0 5px 20px rgba(0,0,0,0.2);
                    z-index: 1000;
                    animation: slideIn 0.3s ease;
                    font-weight: 500;
                `;
        notification.textContent = message;
        document.body.appendChild(notification);

        setTimeout(() => {
            notification.style.animation = 'slideOut 0.3s ease';
            setTimeout(() => notification.remove(), 300);
        }, 3000);
    }

    // Add animations if they don't exist
    const style = document.createElement('style');
    style.textContent = `
        @@keyframes slideIn {
                    from { transform: translateX(100%); opacity: 0; }
                    to { transform: translateX(0); opacity: 1; }
                }
        @@keyframes slideOut {
                    from { transform: translateX(0); opacity: 1; }
                    to { transform: translateX(100%); opacity: 0; }
                }
            `;
    document.head.appendChild(style);
</script>