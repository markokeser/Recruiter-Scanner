<div id="toast" class="notification" style="display: none;"></div>

<script>
    let matchResults = {};
    let currentSortOrder = 'desc';
    let currentSortField = 'score';
    let recruitersData = @Html.Raw(Model != null && Model.Recruiters != null ? Json.Serialize(Model.Recruiters) : "[]");

    const DEMO_CV_FULL = `SOFTWARE ENGINEER - FULL STACK DEVELOPER

PERSONAL INFORMATION
Location: Barcelona, Spain (EU Citizen)
Languages: English (Fluent), Serbian (Native), Spanish (Learning)

PROFESSIONAL SUMMARY
Full Stack Developer with 5+ years of experience building scalable web applications and AI integrations.

TECHNICAL SKILLS
• Backend: C# / .NET Core, Java, Node.js, Python
• Frontend: JavaScript, TypeScript, React, Vue.js
• Databases: SQL Server, PostgreSQL, MongoDB
• Cloud & DevOps: Azure, AWS, Docker, Kubernetes
• AI & Tools: OpenAI API, LangChain, Prompt Engineering

WORK EXPERIENCE
• Senior Full Stack Developer (2022-Present) - Leading team of 4 developers
• Full Stack Developer (2020-2022) - Fintech web applications
• Backend Developer (2018-2020) - RESTful APIs, database optimization

EDUCATION
• Master's in Computer Science - University of Barcelona
• Bachelor's in Software Engineering - Faculty of Technical Sciences`;

    const DEMO_CSV_CONTENT = `Company Name for Emails,Website,First Name,Last Name,Person Linkedin Url,Title,Email,Email Status,Corporate Phone,# Employees,Company Linkedin Url,Facebook Url,Twitter Url,City,State,Country,Company Address,Company City
GitHub,https://github.com,Alex,Chen,http://www.linkedin.com/in/alex-chen-github,Technical Recruiter - Developer Platforms,alex.chen@github.com,Verified,+1 415-735-4488,1200,https://www.linkedin.com/company/github,https://www.facebook.com/GitHub,https://twitter.com/github,Barcelona,Catalonia,Spain,"88 Colin P Kelly Jr St, San Francisco, CA, United States, 94107",San Francisco
Goldman Sachs,https://goldmansachs.com,Sofia,Rodriguez,http://www.linkedin.com/in/sofia-rodriguez-gs,Tech Recruiter - Investment Banking Tech,sofia.rodriguez@gs.com,Verified,+1 212-902-1000,48500,https://www.linkedin.com/company/goldman-sachs,https://www.facebook.com/GoldmanSachs,https://twitter.com/GoldmanSachs,Barcelona,Catalonia,Spain,"200 West Street, New York, NY, United States, 10282",New York
Zara,https://zara.com,David,Martinez,http://www.linkedin.com/in/david-martinez-inditex,Retail Recruitment Specialist,david.martinez@zara.com,Verified,+34 981 18 54 00,45000,https://www.linkedin.com/company/inditex,https://www.facebook.com/zara,https://twitter.com/ZARA,Barcelona,Catalonia,Spain,"Avenida de la Diputacion, Arteixo, A Coruna, Spain, 15142",Arteixo`;

    function triggerFileUpload() {
        document.getElementById('heroCsvFile').click();
    }

    document.getElementById('heroCsvFile')?.addEventListener('change', function(e) {
        if (e.target.files[0]?.name) {
            document.getElementById('heroUploadForm').submit();
        }
    });

    document.getElementById('csvFile')?.addEventListener('change', function(e) {
        var fileName = e.target.files[0]?.name;
        var label = document.getElementById('fileLabel');
        if (fileName) {
            label.innerHTML = '📄 ' + fileName;
            label.style.background = '#d4edda';
            label.style.borderColor = '#28a745';
            document.getElementById('uploadForm').submit();
        } else {
            label.innerHTML = '📁 Choose CSV file';
            label.style.background = '#e9ecef';
            label.style.borderColor = '#adb5bd';
        }
    });

    function showDemoFileModal() {
        document.getElementById('demoFileModal').style.display = 'flex';
    }

    function closeDemoModal() {
        document.getElementById('demoFileModal').style.display = 'none';
    }

    function uploadDemoFile() {
        closeDemoModal();
        showNotification('Loading demo CV and recruiters...', 'info');
        localStorage.setItem('userCV', DEMO_CV_FULL);
        showNotification('✅ Demo CV loaded!', 'success');

        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/Home/Upload';
        form.style.display = 'none';
        form.enctype = 'multipart/form-data';

        const blob = new Blob([DEMO_CSV_CONTENT], { type: 'text/csv' });
        const file = new File([blob], 'demo_recruiters.csv', { type: 'text/csv' });
        const dataTransfer = new DataTransfer();
        dataTransfer.items.add(file);

        const fileInput = document.createElement('input');
        fileInput.type = 'file';
        fileInput.name = 'csvFile';
        fileInput.files = dataTransfer.files;
        form.appendChild(fileInput);

        document.body.appendChild(form);
        form.submit();
        setTimeout(() => { document.body.removeChild(form); }, 2000);
    }

    function updateStatsFromModel() {
    @if (Model.ShowResults && Model.Recruiters.Any())
    {
        <text>
        document.getElementById('totalRecruiters').innerText = '@Model.Recruiters.Count';
        document.getElementById('verifiedEmails').innerText = '@Model.Recruiters.Count(r => r.EmailStatus?.ToLower() == "verified")';
        document.getElementById('withLinkedin').innerText = '@Model.Recruiters.Count(r => !string.IsNullOrEmpty(r.PersonLinkedinUrl) && r.PersonLinkedinUrl != "http://")';
        document.getElementById('withEmail').innerText = '@Model.Recruiters.Count(r => !string.IsNullOrEmpty(r.Email))';
        </text>
    }
    else
    {
        <text>
        document.getElementById('totalRecruiters').innerText = '0';
        document.getElementById('verifiedEmails').innerText = '0';
        document.getElementById('withLinkedin').innerText = '0';
        document.getElementById('withEmail').innerText = '0';
        </text>
    }
    }

    function addRowClickListeners() {
        const rows = document.querySelectorAll('#tableBody tr');
        rows.forEach(row => {
            row.removeEventListener('click', row.clickHandler);
            row.clickHandler = function(e) {
                if (e.target.tagName === 'A' || e.target.closest('a')) return;
                const index = this.getAttribute('data-index');
                if (index && matchResults[index]) {
                    displayMatchResult(matchResults[index]);
                    document.getElementById('matchModal').style.display = 'flex';
                } else if (index) {
                    showNotification('First run batch analysis to get AI results', 'warning');
                }
            };
            row.addEventListener('click', row.clickHandler);
        });
    }

    async function batchAnalyzeAll() {
        matchResults = {};
        const cvData = localStorage.getItem('userCV');
        if (!cvData) { showNotification('Please enter your CV first.', 'warning'); return; }
        if (!recruitersData || recruitersData.length === 0) { showNotification('No recruiter data available.', 'warning'); return; }

        const total = recruitersData.length;
        let completed = 0, failed = 0, startTime = Date.now();
        document.getElementById('progressContainer').style.display = 'block';
        const batchBtn = document.getElementById('batchAnalyzeBtn'), mobileBatchBtn = document.getElementById('mobileBatchAnalyzeBtn');
        const nextBtn = document.getElementById('nextBtn'), mobileNextBtn = document.getElementById('mobileNextBtn');
        if (batchBtn) batchBtn.disabled = true;
        if (mobileBatchBtn) mobileBatchBtn.disabled = true;
        if (nextBtn) nextBtn.disabled = true;
        if (mobileNextBtn) mobileNextBtn.disabled = true;
        showNotification(`Starting analysis of ${total} recruiters...`, 'info');

        for (let i = 0; i < total; i++) {
            const percent = Math.round((i / total) * 100);
            const pf = document.getElementById('progressFill'), pp = document.getElementById('progressPercent'), pt = document.getElementById('progressText');
            if (pf) pf.style.width = percent + '%';
            if (pp) pp.innerHTML = percent + '%';
            if (pt) pt.innerHTML = `Analyzing ${i + 1}/${total}: ${recruitersData[i]?.companyNameForEmails || 'N/A'}`;

            try {
                const response = await fetch('/Home/AnalyzeMatch', {
                    method: 'POST', headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ recruiterIndex: i, recruiter: recruitersData[i], cvData: cvData })
                });
                const data = await response.json();
                if (data.success) {
                    matchResults[i] = data.data;
                    updateScoreInTable(i, data.data.score);
                    completed++;
                } else { failed++; }
                updateNextButton();
                if (i < total - 1) await new Promise(resolve => setTimeout(resolve, 1500));
            } catch (error) { console.error('Error:', error); failed++; }
        }

        let totalTime = Math.round((Date.now() - startTime) / 1000);
        const pf = document.getElementById('progressFill'), pp = document.getElementById('progressPercent'), pt = document.getElementById('progressText');
        if (pf) pf.style.width = '100%';
        if (pp) pp.innerHTML = '100%';
        if (pt) pt.innerHTML = `Analysis completed in ${totalTime}s. Success: ${completed}, Failed: ${failed}`;
        setTimeout(() => { const pc = document.getElementById('progressContainer'); if (pc) pc.style.display = 'none'; }, 5000);
        if (batchBtn) batchBtn.disabled = false;
        if (mobileBatchBtn) mobileBatchBtn.disabled = false;
        if (completed === total) {
            if (nextBtn) nextBtn.disabled = false;
            if (mobileNextBtn) mobileNextBtn.disabled = false;
        }
        showNotification(`✅ Analysis complete! Click on any row for details.`, 'success');
        applySort();
        addRowClickListeners();
    }

    function updateScoreInTable(index, score) {
        const row = document.querySelector(`tr[data-index="${index}"]`);
        if (row) {
            const scoreCell = row.querySelector('.score-cell');
            const scoreSpan = scoreCell.querySelector('.score-badge');
            let scoreClass = 'score-pending', scoreText = '⏳ N/A';
            if (score) {
                if (score >= 8) scoreClass = 'score-high';
                else if (score >= 5) scoreClass = 'score-medium';
                else scoreClass = 'score-low';
                scoreText = `${score}/10`;
            }
            scoreSpan.className = `score-badge ${scoreClass}`;
            scoreSpan.innerHTML = scoreText;
            scoreCell.setAttribute('data-score', score || 0);
        }
    }

    function updateNextButton() {
        const nextBtn = document.getElementById('nextBtn'), mobileNextBtn = document.getElementById('mobileNextBtn');
        const total = recruitersData ? recruitersData.length : 0;
        const analyzed = Object.keys(matchResults).length;
        if (total > 0 && analyzed === total) {
            if (nextBtn) nextBtn.disabled = false;
            if (mobileNextBtn) mobileNextBtn.disabled = false;
        } else {
            if (nextBtn) nextBtn.disabled = true;
            if (mobileNextBtn) mobileNextBtn.disabled = true;
        }
    }

    function goToNextStep() {
        const results = [];
        if (Object.keys(matchResults).length === 0) { showNotification('No results to process.', 'warning'); return; }
        for (let index in matchResults) {
            if (matchResults[index] && matchResults[index].score) {
                const recruiter = recruitersData[index] || {};
                const match = matchResults[index];
                results.push({
                    companyName: recruiter.companyNameForEmails || 'N/A', website: recruiter.website || '',
                    city: recruiter.city || '', country: recruiter.country || '',
                    recruiterName: `${recruiter.firstName || ''} ${recruiter.lastName || ''}`.trim() || 'N/A',
                    recruiterTitle: recruiter.title || 'N/A', recruiterEmail: recruiter.email || 'N/A',
                    emailStatus: recruiter.emailStatus || 'N/A', recruiterLinkedIn: recruiter.personLinkedinUrl || 'N/A',
                    companyLinkedIn: recruiter.companyLinkedinUrl || 'N/A', MatchScore: match.score || 0,
                    reasoning: match.reasoning || '', companyAnalysis: match.companyAnalysis || '',
                    locationMatch: match.locationMatch || '', industryMatch: match.industryMatch || '',
                    keyFindings: match.keyFindings || '', strengths: match.strengths || [],
                    weaknesses: match.weaknesses || [], analyzedAt: new Date().toISOString()
                });
            }
        }
        if (results.length === 0) { showNotification('No valid results.', 'warning'); return; }
        results.sort((a, b) => b.MatchScore - a.MatchScore);
        const jsonStr = JSON.stringify(results, null, 2);
        const blob = new Blob([jsonStr], { type: 'application/json' });
        const file = new File([blob], `match_results_${new Date().toISOString().slice(0, 10)}.json`, { type: 'application/json' });
        const form = document.createElement('form');
        form.method = 'POST'; form.action = '/EmailGeneration/UploadJson'; form.enctype = 'multipart/form-data'; form.style.display = 'none';
        const fileInput = document.createElement('input'); fileInput.type = 'file'; fileInput.name = 'jsonFile';
        const dataTransfer = new DataTransfer(); dataTransfer.items.add(file); fileInput.files = dataTransfer.files;
        form.appendChild(fileInput); document.body.appendChild(form); form.submit();
        setTimeout(() => document.body.removeChild(form), 2000);
    }

    function applySort() {
        const sortField = document.getElementById('sortSelect').value;
        const tbody = document.getElementById('tableBody');
        if (!tbody) return;
        const rows = Array.from(tbody.querySelectorAll('tr'));
        rows.sort((a, b) => {
            let aVal, bVal;
            switch (sortField) {
                case 'score': aVal = parseFloat(a.querySelector('.score-cell')?.getAttribute('data-score') || '0'); bVal = parseFloat(b.querySelector('.score-cell')?.getAttribute('data-score') || '0'); break;
                case 'company': aVal = a.getAttribute('data-company') || ''; bVal = b.getAttribute('data-company') || ''; break;
                case 'location': aVal = a.getAttribute('data-location') || ''; bVal = b.getAttribute('data-location') || ''; break;
                case 'emailStatus': aVal = a.getAttribute('data-emailstatus') || ''; bVal = b.getAttribute('data-emailstatus') || ''; break;
                default: return 0;
            }
            if (currentSortOrder === 'desc') return aVal > bVal ? -1 : aVal < bVal ? 1 : 0;
            else return aVal < bVal ? -1 : aVal > bVal ? 1 : 0;
        });
        while (tbody.firstChild) tbody.removeChild(tbody.firstChild);
        rows.forEach(row => tbody.appendChild(row));
        setTimeout(addRowClickListeners, 100);
    }

    function toggleSortOrder() {
        const btn = document.getElementById('sortOrderBtn');
        if (currentSortOrder === 'desc') { currentSortOrder = 'asc'; btn.innerHTML = '🔼 Ascending'; }
        else { currentSortOrder = 'desc'; btn.innerHTML = '🔽 Descending'; }
        applySort();
    }

    function displayMatchResult(result) {
        let scoreColor = result.score >= 8 ? '#28a745' : (result.score >= 5 ? '#ffc107' : '#dc3545');
        let strengthsHtml = result.strengths?.length ? result.strengths.map(s => `<li>✅ ${s}</li>`).join('') : '<li style="color: #999;">No specific strengths mentioned</li>';
        let weaknessesHtml = result.weaknesses?.length ? result.weaknesses.map(w => `<li>⚠️ ${w}</li>`).join('') : '<li style="color: #999;">No specific weaknesses mentioned</li>';
        document.getElementById('matchContent').innerHTML = `
            <div style="text-align: center; margin-bottom: 20px;"><div class="score-circle" style="background: ${scoreColor};">${result.score}/10</div><div style="font-size: 18px;">Match Score</div></div>
            <div style="margin: 20px 0; padding: 15px; background: #f8f9fa; border-radius: 12px;"><h4>📊 Overall Assessment</h4><p>${result.reasoning || 'No description'}</p></div>
            <div class="analysis-grid">
                <div class="analysis-item" style="background: #e8f4fd;"><h5>🏢 Company Analysis</h5><p>${result.companyAnalysis || 'N/A'}</p></div>
                <div class="analysis-item" style="background: #f0f7e8;"><h5>📍 Location Match</h5><p>${result.locationMatch || 'N/A'}</p></div>
                <div class="analysis-item" style="background: #fff3cd;"><h5>🔧 Industry Match</h5><p>${result.industryMatch || 'N/A'}</p></div>
                <div class="analysis-item" style="background: #d4edda;"><h5>💡 Key Finding</h5><p>${result.keyFindings || 'N/A'}</p></div>
            </div>
            <div><h4>💪 Strengths</h4><ul class="strengths-list">${strengthsHtml}</ul></div>
            <div><h4>📉 Areas for Improvement</h4><ul class="weaknesses-list">${weaknessesHtml}</ul></div>
        `;
    }

    function closeModal() { document.getElementById('matchModal').style.display = 'none'; document.getElementById('matchContent').innerHTML = ''; }

    function showNotification(message, type) {
        const toast = document.getElementById('toast');
        toast.textContent = message;
        toast.className = `notification notification-${type}`;
        toast.style.display = 'block';
        setTimeout(() => {
            toast.style.animation = 'slideOut 0.3s ease';
            setTimeout(() => { toast.style.display = 'none'; toast.style.animation = ''; }, 300);
        }, 3000);
    }

    document.addEventListener('DOMContentLoaded', function() {
        const savedCV = localStorage.getItem('userCV');
        const cvStatus = document.getElementById('cvStatus');
        if (savedCV && cvStatus) cvStatus.style.display = 'inline-block';
        updateStatsFromModel();
        updateNextButton();
        addRowClickListeners();
    });

    window.onclick = function(event) {
        if (event.target == document.getElementById('matchModal')) closeModal();
        if (event.target == document.getElementById('demoFileModal')) closeDemoModal();
    }
</script>